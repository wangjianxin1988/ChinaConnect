  "coordinates": {
    "lat": 40.9515,
    "lng": 117.963
  },
  "timezone": "UTC+8 (China Standard Time)",
  "description": "Chengde, a historic mountain city in Hebei province, is famous for its imperial summer resort and nearby Buddhist temples. A UNESCO World Heritage Site, it was once the summer retreat for Qing Dynasty emperors. The mountain scenery and Tibetan-style Buddhist temples make it unique.",
  "coverImage": "https://images.unsplash.com/photo-1573824398985-ca6aee6b0cbd?w=1200&q=80",
  "highlights": [
    "Mountain Resort - Qing Dynasty summer palace",
    "Puning Temple - Largest Buddhist temple in China",
    "Putuo Zongcheng Temple - Tibetan-style temple",
    "Small Potala Palace - Miniature of Lhasa's Potala",
    "Imperial summer retreat"
  ],
  "climate": {
    "type": "Temperate continental climate",
    "bestMonths": [
      "May",
      "June",
      "September",
      "October"
    ],
    "avgSummerTemp": "24°C (75°F)",
    "avgWinterTemp": "-8°C (18°F)",
    "tips": "Best in summer for resort and temples. Spring and autumn pleasant. Winters cold. Summer is peak season but pleasant escape from Beijing heat."
  },
  "attractions": [
    {
      "id": "chengde-1",
      "name": "避暑山庄",
