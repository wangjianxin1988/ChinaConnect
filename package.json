{
  "name": "chinaconnect",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "db:generate": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID > src/types/database.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit src/__tests__/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:update": "playwright test --update-snapshots",
    "test:e2e:report": "playwright show-report",
    "test:e2e:city": "playwright test tests/e2e/city-search.spec.ts",
    "test:e2e:emergency": "playwright test tests/e2e/emergency-sos.spec.ts",
    "test:e2e:ai": "playwright test tests/e2e/ai-chat.spec.ts",
    "test:e2e:auth": "playwright test tests/e2e/auth.spec.ts",
    "test:e2e:smoke": "playwright test tests/e2e/homepage.spec.ts tests/e2e/auth.spec.ts tests/e2e/city-pages.spec.ts --project=chromium",
    "test:e2e:ci": "playwright test --project=chromium --reporter=list",
    "test:e2e:all": "playwright test --reporter=list",
    "test:e2e:grep": "playwright test --grep",
    "test:all": "pnpm test && pnpm test:e2e",
    "test:ci": "pnpm test && pnpm test:e2e:ci",
    "playwright:install": "playwright install --with-deps chromium",
    "playwright:install:all": "playwright install --with-deps",
    "playwright:install-deps": "playwright install-deps",
    "lhci:build": "lhci build",
    "lhci:autorun": "lhci autorun",
    "lhci:collect": "lhci collect",
    "lhci:assert": "lhci assert"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^12.6.13",
    "@astrojs/node": "^10.1.1",
    "@astrojs/react": "^4.2.1",
    "@astrojs/tailwind": "^6.0.2",
    "@radix-ui/react-slot": "^1.1.1",

    "@supabase/supabase-js": "^2.49.1",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^11.0.0",
    "astro": "^5.5.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "uuid": "^14.0.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@lhci/cli": "^0.14.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.19",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}