  "culturalTips": [
    {
      "category": "gardens",
      "title": "Garden Etiquette",
      "content": "Suzhou's classical gardens are UNESCO sites. Walk quietly, don't touch plants. Morning visits offer best photos and fewer crowds. Each garden tells a philosophical story.",
      "importance": "high"
    },
    {
      "category": "silk",
      "title": "Silk Culture",
      "content": "Suzhou is famous for silk production. Visit silk factory to see weaving demonstrations. Real silk costs more - bargain at markets. Embroidery is another famous craft.",
      "importance": "medium"
    },
    {
      "category": "food",
      "title": "Suzhou Cuisine",
      "content": "Suzhou food is lighter and sweeter than Shanghai. Must-try: Song Shu (squirrel-shaped mandarin fish), Wusong duck, and crab dishes in season. Eat breakfast at traditional teahouses.",
      "importance": "high"
    },
    {
      "category": "water-towns",
      "title": "Water Town Visits",
      "content": "Zhouzhuang and Tongli are the main water towns. Zhouzhuang is more famous but crowded. Tongli is quieter. Go early morning. Combine two in one day is rushed.",
      "importance": "medium"
    },
    {
      "category": "etiquette",
      "title": "Greeting Etiquette",
      "content": "Greet with both hands pressed together slightly鞠躬 is traditional. Handshakes also acceptable. Address people by title and surname.",
      "importance": "medium"
    },
    {
      "category": "dining",
      "title": "Dining Customs",
      "content": "Wait for host to start eating. Leave some food on plate to show you are full. Tapping chopsticks is considered rude.",
      "importance": "high"
    },
    {
      "category": "dress",
      "title": "Dress Code",
      "content": "Smart casual for restaurants. Remove shoes when entering homes and some traditional buildings. Cover shoulders at temples.",
      "importance": "low"
    },
    {
      "category": "bargaining",
      "title": "Shopping and Bargaining",
      "content": "Bargaining expected at markets. Start at 30-40% of asking price. Be friendly but firm. Most fixed-price shops have reasonable prices.",
      "importance": "medium"
    },
    {
      "category": "language",
      "title": "Language Tips",
      "content": "Mandarin is official. Suzhou dialect is soft and melodic. Learn basic phrases: 你好 (hello), 谢谢 (thank you), 请问 (excuse me).",
      "importance": "medium"
    },
    {
      "category": "transport",
      "title": "Getting Around",
      "content": "Suzhou is bike-friendly with flat terrain. Metro is efficient. Didi works well. Walking in old town reveals hidden gems.",
      "importance": "low"
    },
    {
      "category": "photography",
      "title": "Photography Ethics",
      "content": "Ask permission before photographing people. Some temples prohibit photography inside. Flash may damage ancient artifacts.",
      "importance": "low"
    },
    {
      "category": "silk",
      "title": "Silk Shopping Guide",
      "content": "Real silk costs more. Check for certification. Silk fabric is sold by the meter. Haggle at markets but not at branded stores.",
      "importance": "medium"
    },
    {
      "category": "garden",
      "title": "Garden Visitation",
      "content": "Arrive early (7:30-8:00) to avoid tour groups. Humble Administrator and Lingering are most famous. Garden pass saves money.",
      "importance": "medium"
    },
    {
      "category": "seasonal",
      "title": "Best Seasons",
      "content": "Spring (April-May) for flowers and pleasant weather. Autumn (Sept-Nov) for chrysanthemums and cool evenings. Summer is hot and humid.",
      "importance": "low"
    },
    {
      "category": "tea",
      "title": "Tea Culture",
      "content": "Suzhou is famous for Biluochun tea. Visit tea houses for authentic experience. Best tea shops are near the gardens.",
      "importance": "medium"
    },
    {
      "category": "arts",
      "title": "Kunqu Opera",
      "content": "Kunqu opera is Suzhou most famous performing art. Watch a performance at the Kunqu Museum or in gardens at night.",
      "importance": "low"
    },
    {
      "category": "water",
      "title": "Water Town Etiquette",
      "content": "When visiting water towns like Zhouzhuang, be respectful of local residents. Do not block doorways or photograph interiors without permission.",
      "importance": "low"
    }
  ],
