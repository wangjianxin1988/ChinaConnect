  "culturalTips": [
    {
      "category": "history",
      "title": "Sino-Japanese War Heritage",
      "content": "Weihai is historically significant as the location where the First Sino-Japanese War (1894-95) began. Liugong Island features naval fortifications and museums commemorating this period.",
      "importance": "high"
    },
    {
      "category": "food",
      "title": "Seafood Culture",
      "content": "Weihai is famous for fresh seafood including abalone, sea urchin, clams, and various fish. The city has strong seafood culture with many restaurants offering fresh catches daily.",
      "importance": "high"
    },
    {
      "category": "korean",
      "title": "Korean Influence",
      "content": "Due to proximity to Korea and Korean investment, Weihai has a significant Korean community, especially in the Korean Cultural Block. Authentic Korean food is readily available.",
      "importance": "high"
    },
    {
      "category": "beach",
      "title": "Beach Culture",
      "content": "Weihai has beautiful beaches including Golden Beach and Silver Beach. Summer (July-August) is peak season for swimming. The beaches are generally clean and well-maintained.",
      "importance": "medium"
    },
    {
      "category": "dialect",
      "title": "Weihai Dialect",
      "content": "Weihai dialect is part of Ji-Lu Mandarin with some unique words. The local accent is known for being direct. Korean influence has introduced some Korean loanwords.",
      "importance": "low"
    },
    {
      "category": "timing",
      "title": "Best Time to Visit",
      "content": "Weihai is best visited May-September for beach season. July-August is peak swimming season but crowded. June and September offer pleasant weather with fewer crowds.",
      "importance": "medium"
    },
    {
      "category": "nature",
      "title": "Island Hopping",
      "content": "Weihai has several beautiful islands including Liugong Island, Chengshan Island, and Haiyu Island. Each offers unique scenery from naval history to seabird colonies.",
      "importance": "medium"
    },
    {
      "category": "food",
      "title": "Must-Try Dishes",
      "content": "Weihai specialties include: sea urchin (海胆), abalone (鲍鱼), steamed sea bass, sea intestine rice (海肠捞饭), and fresh clams.",
      "importance": "high"
    },
    {
      "category": "winter",
      "title": "Winter Swan Migration",
      "content": "Swan Lake in Rongcheng attracts hundreds of migrating swans from Siberia from December to February. This creates a unique winter tourism opportunity.",
      "importance": "medium"
    },
    {
      "category": "transportation",
      "title": "Getting Around",
      "content": "Weihai is best explored by car or taxi. Attractions are spread out across different districts. Didi works well for transportation. Bus network covers main areas but can be slow.",
      "importance": "medium"
    },
    {
      "category": "weather",
      "title": "Coastal Weather",
      "content": "Weihai has pleasant sea breezes in summer making it cooler than inland areas. However, winter can be cold and windy. Fog is common in spring.",
      "importance": "medium"
    },
    {
      "category": "nightlife",
      "title": "Evening Entertainment",
      "content": "Weihai has growing nightlife centered around the Korean Cultural Block, coastal zone, and beach areas. The Happiness Gate area is popular for evening walks.",
      "importance": "low"
    },
    {
      "category": "culture",
      "title": "Korean Cultural Block",
      "content": "The Korean Cultural Block (韩乐坊) is a vibrant area with Korean restaurants, shops, and entertainment. Experience authentic Korean culture without leaving China.",
      "importance": "medium"
    },
    {
      "category": "shopping",
      "title": "Local Products",
      "content": "Weihai is known for local products including dried seafood, Korean cosmetics, and regional specialties. The night markets offer good shopping opportunities.",
      "importance": "low"
    },
    {
      "category": "eco",
      "title": "Environmental Protection",
      "content": "Weihai has strong environmental protection policies with clean beaches and seawater. The city has received awards for urban environmental improvement.",
      "importance": "low"
    }
  ],
