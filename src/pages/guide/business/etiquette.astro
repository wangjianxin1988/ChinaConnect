---
import EtiquetteClient from "@/components/Guide/EtiquetteClient";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Chinese Business Etiquette Guide - ChinaConnect"
  description="Master Chinese business etiquette including business card exchange, dining, meetings, and gift giving. Practical do's and don'ts for foreign business professionals."
  meta={{
    keywords: ['Chinese business etiquette', '中国商务礼仪', 'business card exchange China', 'Chinese dining etiquette', '商务礼仪'],
  }}
>
  <main class="container mx-auto px-4 py-8">
    <div class="mb-8">
      <a href="/guide" class="text-primary hover:underline mb-4 inline-block flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Business Express / 商务快车道
      </a>
      <div class="flex items-center gap-3 mb-3">
        <span class="text-4xl">🎯</span>
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-foreground">Business Etiquette Essentials</h1>
          <p class="text-muted-foreground text-lg">商务礼仪速成</p>
        </div>
      </div>
      <p class="text-muted-foreground max-w-2xl">
        Master the unwritten rules of Chinese business culture. From business card exchange to dining etiquette —
        practical guidance to help you earn respect and build lasting relationships.
      </p>
    </div>

    <EtiquetteClient client:load />
  </main>
</BaseLayout>