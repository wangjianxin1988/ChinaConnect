  "culturalTips": [
    {
      "category": "history",
      "title": "Qing Dynasty Summer Retreat",
      "content": "Chengde was the summer retreat for Qing Dynasty emperors. The Mountain Resort served as a second capital, where emperors conducted government affairs away from Beijing's summer heat.",
      "importance": "high"
    },
    {
      "category": "religion",
      "title": "Tibetan Buddhism",
      "content": "The temples around Chengde reflect the importance of Tibetan Buddhism to the Qing court. The Potala-style temples were built to honor Tibetan Buddhist leaders.",
      "importance": "high"
    },
    {
      "category": "manchu",
      "title": "Manchu Culture",
      "content": "Chengde is a center of Manchu culture. Try traditional Manchu dishes and experience the cultural heritage of the Qing ruling class.",
      "importance": "medium"
    },
    {
      "category": "nature",
      "title": "Mountain Resort Design",
      "content": "The Mountain Resort incorporates natural mountain scenery into its design. The resort area includes lakes, grasslands and forests creating a microcosm of China.",
      "importance": "medium"
    },
    {
      "category": "food",
      "title": "Local Cuisine",
      "content": "Chengde cuisine reflects its northern location. Try wild mushrooms from nearby forests, venison, and traditional Manchu dishes like hotpot.",
      "importance": "medium"
    },
    {
      "category": "proximity",
      "title": "Gateway to Beijing",
      "content": "Chengde is a popular escape from Beijing's summer heat, just 3-4 hours by bus. Many Beijing residents visit for weekend retreats.",
      "importance": "high"
    },
    {
      "category": "great-wall",
      "title": "Nearby Great Wall",
      "content": "Jinshanling Great Wall is accessible from Chengde. This well-preserved section is less crowded than Badaling and great for hiking.",
      "importance": "medium"
    },
    {
      "category": "grassland",
      "title": "Mulan Weichang",
      "content": "The Mulan Weichang hunting ground near Chengde was used by Qing emperors for annual hunts. Today it offers grassland scenery and Mongolian cultural experiences.",
      "importance": "medium"
    },
    {
      "category": "architecture",
      "title": "Imperial Architecture",
      "content": "Chengde's Mountain Resort showcases unique imperial architecture combining Han and Mongolian styles. The temples feature golden roofs and Tibetan Buddhist design elements.",
      "importance": "high"
    },
    {
      "category": "nature",
      "title": "Northern Grasslands",
      "content": "The grasslands near Chengde offer a stark contrast to Beijing. The Mulan Weichang hunting ground spans vast grasslands where you can experience horse riding and Mongolian culture.",
      "importance": "medium"
    },
    {
      "category": "food",
      "title": "Wild Forest Mushrooms",
      "content": "Chengde's surrounding forests produce prized wild mushrooms. These are featured in local dishes and are considered a delicacy. Try mushroom hotpot at local restaurants.",
      "importance": "medium"
    },
    {
      "category": "hot-spring",
      "title": "Imperial Hot Springs",
      "content": "The hot springs near the Mountain Resort were used by Qing emperors. Today you can experience these same hot springs at local resorts.",
      "importance": "medium"
    },
    {
      "category": "performance",
      "title": "Traditional Performances",
      "content": "Traditional Manchu and Mongolian performances are held at the Mountain Resort. These include folk dances, horse shows, and imperial ceremony reenactments.",
      "importance": "low"
    },
    {
      "category": "shopping",
      "title": "Local Products",
      "content": "Chengde is known for wild mushrooms, pine nuts, and Chinese medicinal herbs. The night markets sell local specialties and traditional crafts.",
      "importance": "low"
    },
    {
      "category": "etiquette",
      "title": "Temple Etiquette",
      "content": "When visiting Buddhist temples, dress modestly and remove hats. Some temples may have restrictions on photography. Light incense with respect.",
      "importance": "medium"
    }
  ],
