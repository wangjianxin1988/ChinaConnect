---
import TranslationServiceClient from "@/components/Guide/TranslationServiceClient";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Translation & Interpreting Services - ChinaConnect"
  description="Book professional interpreters and translators in China. Consecutive interpreting, simultaneous interpreting, document translation, and certified translations for legal use."
  meta={{
    keywords: ['interpreter China', '翻译服务中国', 'Chinese translator booking', 'consecutive interpreting China', '同声传译'],
  }}
>
  <main class="container mx-auto px-4 py-8">
    <div class="mb-8">
      <a href="/guide" class="text-primary hover:underline mb-4 inline-block flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Business Express / 商务快车道
      </a>
      <div class="flex items-center gap-3 mb-3">
        <span class="text-4xl">🌍</span>
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-foreground">Translation & Interpreting</h1>
          <p class="text-muted-foreground text-lg">翻译服务预约</p>
        </div>
      </div>
      <p class="text-muted-foreground max-w-2xl">
        Book professional interpreters and translators for your business visits in China.
        From consecutive interpreting at meetings to certified document translation for visa applications.
      </p>
    </div>

    <TranslationServiceClient client:load />
  </main>
</BaseLayout>