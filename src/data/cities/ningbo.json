  "culturalTips": [
    {
      "category": "history",
      "title": "Ancient Port City",
      "content": "Ningbo is one of China's oldest port cities, dating back over 1,000 years. It was a major stop on the Maritime Silk Road and remains an important port today.",
      "importance": "high"
    },
    {
      "category": "library",
      "title": "Tianyi Pavilion",
      "content": "The Tianyi Pavilion is China's oldest private library, built in 1561. The name means 'First under Heaven' and it houses rare books and classical gardens.",
      "importance": "high"
    },
    {
      "category": "food",
      "title": "Ningbo Cuisine",
      "content": "Ningbo cuisine is known for its sweet and savory flavors. Must-try: soup dumplings (汤团), rice cakes (年糕), and the famous stinky vegetable (臭菜).",
      "importance": "high"
    },
    {
      "category": "buddhism",
      "title": "Buddhist Heritage",
      "content": "Ningbo is an important Buddhist center with ancient temples like Tiantong Temple and Ayuwang Temple that date back over 1,700 years.",
      "importance": "medium"
    },
    {
      "category": "water",
      "title": "Water Towns",
      "content": "The area around Ningbo has several ancient water towns like Qiantong that offer a glimpse of traditional Chinese life along canals.",
      "importance": "medium"
    },
    {
      "category": "seafood",
      "title": "Fresh Seafood",
      "content": "Being a coastal city, Ningbo is famous for fresh seafood. The Dongqian Lake area has famous 'boat cuisine' with fish caught from the lake.",
      "importance": "high"
    },
    {
      "category": "architecture",
      "title": "Colonial Architecture",
      "content": "The Old Bund shows European colonial influence from the 1800s when Ningbo was a treaty port. The architecture blends Chinese and Western styles.",
      "importance": "medium"
    },
    {
      "category": "tea",
      "title": "Tea Culture",
      "content": "Ningbo has famous green tea plantations on Fuquan Mountain overlooking Dongqian Lake. Tea picking and tasting can be combined with hiking.",
      "importance": "medium"
    },
    {
      "category": "legend",
      "title": "Butterfly Lovers",
      "content": "The famous Chinese legend 'Butterfly Lovers' (梁祝) is set in the Ningbo area. The Liangshanbo Park tells this romantic story.",
      "importance": "low"
    },
    {
      "category": "dialect",
      "title": "Ningbo Dialect",
      "content": "Ningbo dialect is a distinct Wu Chinese dialect, different from Mandarin. It preserves ancient Chinese pronunciation features valued by linguists.",
      "importance": "low"
    },
    {
      "category": "business",
      "title": "Business Hub",
      "content": "Ningbo is a major commercial hub with busy ports. The city has thriving trade and manufacturing industries.",
      "importance": "medium"
    },
    {
      "category": "nature",
      "title": "Dongqian Lake",
      "content": "Dongqian Lake is one of Zhejiang's most beautiful lakes with scenic bike paths, gardens, and temples to explore. Rent a bike to tour the lake.",
      "importance": "high"
    },
    {
      "category": "art",
      "title": "Calligraphy Heritage",
      "content": "Ningbo has produced many famous calligraphers. The Shamenghai Academy honors the famous calligrapher and offers cultural exhibits.",
      "importance": "low"
    },
    {
      "category": "temple",
      "title": "Buddhist Mountains",
      "content": "Xuedou Mountain is a sacred Buddhist mountain with the world's largest Maitreya Buddha statue. Combined with hiking and temple visits.",
      "importance": "medium"
    },
    {
      "category": "snacks",
      "title": "Famous Snacks",
      "content": "Ningbo has many famous snacks: oil-fried dough twists (油赞子), rice cakes (年糕), and sweet rice dumplings (汤团) are must-tries.",
      "importance": "medium"
    },
    {
      "category": "handicrafts",
      "title": "Traditional Crafts",
      "content": "Look for traditional Ningbo crafts like Zhoushan wood carving and local embroidery as souvenirs from the area.",
      "importance": "low"
    }
  ],
