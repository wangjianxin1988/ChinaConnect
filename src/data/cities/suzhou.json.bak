{
  "slug": "suzhou",
  "name": "苏州",
  "nameEn": "Suzhou",
  "country": "China",
  "population": "10.7 million",
  "coordinates": {
    "lat": 31.2989,
    "lng": 120.5853
  },
  "timezone": "UTC+8 (China Standard Time)",
  "description": "Suzhou is a paradise of elegant gardens, silk production, and classical Chinese culture. Known as 'Venice of the East' for its canals and water towns. Home to UNESCO World Heritage classical gardens, intricate silk embroidery, and 2,500 years of history. A cultural gem between Shanghai and Nanjing.",
  "coverImage": "https://images.unsplash.com/photo-1775486315462-62ea39e31818?w=1200&q=80",
  "highlights": [
    "Humble Administrator's Garden - UNESCO",
    "Lingering Garden - Ming dynasty masterpiece",
    "Tiger Hill - Ancient pagoda and hill",
    "Shantang Street - Classic canal street",
    "Zhouzhuang - Water town Venice"
  ],
  "climate": {
    "type": "Subtropical monsoon",
    "bestMonths": [
      "April",
      "May",
      "September",
      "October",
      "November"
    ],
    "avgSummerTemp": "28C (82F)",
    "avgWinterTemp": "5C (41F)",
    "tips": "Best in spring (April-May) for garden flowers or autumn (Sept-Nov) for pleasant weather. Summer is hot and humid. Winter is cold but gardens are beautiful in snow. Plum blossoms in winter."
  },
  "attractions": [
    {
      "id": "humble-administrator",
      "name": "拙政园",
      "nameEn": "Humble Administrator's Garden",
      "image": "https://images.unsplash.com/photo-1775486315462-62ea39e31818?w=800&q=85",
      "category": "cultural",
      "description": "The largest and most famous classical Chinese garden, a UNESCO World Heritage site representing garden art at its peak.",
      "address": "178 Northeast Street, Gusu District",
      "coordinates": {
        "lat": 31.3222,
        "lng": 120.6372
      },
      "openingHours": "07:30-17:30 (Summer), 08:00-17:00 (Winter)",
      "ticketPrice": "70¥ (peak), 50¥ (off-peak)",
      "recommendedVisitTime": "2-3 hours",
      "highlights": [
        "Peony garden",
        "Lotus pond",
        "Hall of Distingushed Fishing",
        "Autumn colors"
      ],
      "tips": "Arrive before 8am to avoid tour groups. Audio guide essential. Combine with nearby Suzhou Museum. Best in early morning or late afternoon."
    },
    {
      "id": "lingering-garden",
      "name": "留园",
      "nameEn": "Lingering Garden",
      "image": "https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=800&q=85",
      "category": "cultural",
      "description": "A masterpiece of Ming dynasty garden design, UNESCO World Heritage site known for its sophisticated architecture and layout.",
      "address": "338 Lingering Garden Lane, Gusu District",
      "coordinates": {
        "lat": 31.3122,
        "lng": 120.6272
      },
      "openingHours": "07:30-17:30",
      "ticketPrice": "45¥",
      "recommendedVisitTime": "1.5-2 hours",
      "highlights": [
        "Peak Hall",
        "Lion Grove",
        "Eight-patterned walkway",
        "Magnificent pavilion"
      ],
      "tips": "Smaller than Humble Administrator but considered more refined. Morning visits best for light. Excellent details in rock arrangements."
    },
    {
      "id": "tiger-hill",
      "name": "虎丘",
      "nameEn": "Tiger Hill",
      "image": "https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?w=800&q=85",
      "category": "cultural",
      "description": "An ancient hilltop with the famous Leaning Pagoda, historic temples, and legendary tombs dating back 2,500 years.",
      "address": "88 Tiger Hill Road, Suzhou",
      "coordinates": {
        "lat": 31.3322,
        "lng": 120.5872
      },
      "openingHours": "07:30-17:30",
      "ticketPrice": "80¥",
      "recommendedVisitTime": "2-3 hours",
      "highlights": [
        "Leaning Pagoda (Yunyan Pagoda)",
        "Sword Pool",
        "Crouching Tiger Temple",
        "Thousand-man Rock"
      ],
      "tips": "Legend says buried treasures under the pagoda. Walk to the top for views. Spring for flowers. Can be combined with Shantang Street."
    },
    {
      "id": "shantang-street",
