---
import TransportGuideClient from "@/components/Guide/TransportGuideClient";
import EmbeddedAppRecommendation from "@/components/apps/EmbeddedAppRecommendation";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { generateBreadcrumbSchema, generateHowToSchema, generateJsonLdScript } from "@/lib/seo/schema-org";

// Transport Guide page SEO
const pageTitle = "Transport Guide - ChinaConnect";
const pageDescription = "Complete transport guide for traveling in China. Airport arrival, metro, bus, taxi, high-speed rail, and inter-city transport with step-by-step instructions.";

// Schema.org JSON-LD for Transport Guide
const transportSchemas = [
  generateHowToSchema({
    name: "How to Get Around China as a Tourist",
    description: "Step-by-step guide for navigating transportation in China including airport transfers, metro, high-speed rail, taxis, and inter-city transport.",
    steps: [
      { name: "Airport Arrival", text: "After landing, follow signs to metro or taxi. Airport staff can help with directions." },
      { name: "Get a SIM Card", text: "Purchase a SIM or eSIM at the airport for navigation apps and ride-hailing." },
      { name: "Use Metro or Didi", text: "Major cities have efficient metro systems. Download Metro Man or use WeChat mini-programs." },
      { name: "Book High-Speed Rail", text: "Use 12306 app or station counters to book train tickets. Present passport at pickup." },
      { name: "Navigate with Maps", text: "Use Gaode Maps (高德地图) for most accurate turn-by-turn navigation in China." },
    ],
    totalTime: "PT45M",
  }),
  generateBreadcrumbSchema([
    { name: "Home", url: "https://chinaconnect.com/" },
    { name: "Travel Guide", url: "https://chinaconnect.com/guide" },
    { name: "Transport Guide", url: "https://chinaconnect.com/guide/transport" },
  ]),
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  meta={{
    keywords: ['China transport guide', 'China metro', 'China taxi', 'high speed rail China', 'Didi China', '12306'],
  }}
>
  <!-- Schema.org JSON-LD for SEO/GEO -->
  <script type="application/ld+json" set:html={generateJsonLdScript(transportSchemas)} />

  <main class="container mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm">
      <ol class="flex items-center gap-2 text-muted-foreground">
        <li><a href="/" class="hover:text-foreground transition-colors">Home</a></li>
        <li><span>/</span></li>
        <li><a href="/guide" class="hover:text-foreground transition-colors">Travel Guide</a></li>
        <li><span>/</span></li>
        <li class="text-foreground font-medium">Transport Guide</li>
      </ol>
    </nav>

    <div class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-4xl">🚄</span>
        <div>
          <h1 class="text-4xl font-bold text-foreground">Transport Guide</h1>
          <p class="text-muted-foreground text-lg">交通指南 - Complete guide for getting around China</p>
        </div>
      </div>
    </div>

    <!-- Stage indicator -->
    <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-8">
      <div class="flex items-center gap-2">
        <span class="text-2xl">🛬</span>
        <div>
          <h2 class="font-semibold">Stages 4-7: Arrival to Inter-city Transport</h2>
          <p class="text-sm text-muted-foreground">Airport arrival, local transport, and inter-city travel options</p>
        </div>
      </div>
    </div>

    <TransportGuideClient client:load />

    <!-- Transport App Recommendations -->
    <section class="mt-12">
      <EmbeddedAppRecommendation
        client:visible
        categories={["transport", "maps"]}
        title="Transport & Navigation Apps"
        subtitle="Essential apps for getting around China"
      />
    </section>
  </main>
</BaseLayout>