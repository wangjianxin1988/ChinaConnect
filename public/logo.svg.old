<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="512" height="512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#1e3a5f"/>
      <stop offset="100%" style="stop-color:#0d2137"/>
    </linearGradient>
    <linearGradient id="accent" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#e74c3c"/>
      <stop offset="100%" style="stop-color:#c0392b"/>
    </linearGradient>
    <linearGradient id="gold" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f0c040"/>
      <stop offset="100%" style="stop-color:#d4a017"/>
    </linearGradient>
  </defs>
  
  <!-- Background circle -->
  <circle cx="256" cy="256" r="256" fill="url(#bg)"/>
  
  <!-- Great Wall silhouette - simplified stylized -->
  <g fill="url(#gold)" opacity="0.9">
    <!-- Wall base -->
    <path d="M60 320 Q100 300 140 310 Q180 320 220 305 Q260 290 300 300 Q340 310 380 295 Q420 280 460 300 L460 340 Q420 320 380 335 Q340 350 300 340 Q260 330 220 345 Q180 360 140 350 Q100 340 60 360 Z"/>
    
    <!-- Watchtower 1 -->
    <rect x="130" y="260" width="40" height="60" rx="2"/>
    <path d="M125 260 L150 240 L175 260 Z"/>
    <rect x="135" y="248" width="6" height="12" fill="url(#bg)"/>
    <rect x="151" y="248" width="6" height="12" fill="url(#bg)"/>
    
    <!-- Watchtower 2 -->
    <rect x="330" y="245" width="45" height="65" rx="2"/>
    <path d="M325 245 L352 222 L380 245 Z"/>
    <rect x="336" y="232" width="7" height="13" fill="url(#bg)"/>
    <rect x="353" y="232" width="7" height="13" fill="url(#bg)"/>
    
    <!-- Wall crenellations -->
    <rect x="85" y="295" width="12" height="18" rx="1"/>
    <rect x="105" y="290" width="12" height="18" rx="1"/>
    <rect x="190" y="298" width="12" height="18" rx="1"/>
    <rect x="210" y="293" width="12" height="18" rx="1"/>
    <rect x="260" y="288" width="12" height="18" rx="1"/>
    <rect x="280" y="292" width="12" height="18" rx="1"/>
    <rect x="395" y="280" width="12" height="18" rx="1"/>
    <rect x="415" y="286" width="12" height="18" rx="1"/>
  </g>
  
  <!-- Connection arc / bridge motif -->
  <g fill="none" stroke="#ffffff" stroke-width="4" opacity="0.85">
    <path d="M100 180 Q180 100 256 130 Q332 100 420 180" stroke-dasharray="8,6"/>
    <path d="M140 200 Q210 140 256 160 Q302 140 380 200" stroke-dasharray="6,5"/>
  </g>
  
  <!-- Connection dots -->
  <circle cx="100" cy="180" r="8" fill="#ffffff" opacity="0.9"/>
  <circle cx="256" cy="128" r="10" fill="#ffffff" opacity="0.9"/>
  <circle cx="420" cy="180" r="8" fill="#ffffff" opacity="0.9"/>
  
  <!-- Central "C" letterform with Chinese cloud motif -->
  <g transform="translate(256, 128)">
    <circle cx="0" cy="0" r="28" fill="url(#accent)" opacity="0.95"/>
    <text x="0" y="10" text-anchor="middle" font-family="Georgia, 'Times New Roman', serif" font-size="36" font-weight="bold" fill="white" letter-spacing="-1">C</text>
  </g>
  
  <!-- Text: ChinaConnect -->
  <text x="256" y="420" text-anchor="middle" font-family="'Segoe UI', 'Helvetica Neue', Arial, sans-serif" font-size="52" font-weight="700" fill="white" letter-spacing="2">
    <tspan fill="#ffffff">China</tspan><tspan fill="url(#gold)">Connect</tspan>
  </text>
  
  <!-- Tagline -->
  <text x="256" y="458" text-anchor="middle" font-family="'Segoe UI', 'Helvetica Neue', Arial, sans-serif" font-size="20" fill="rgba(255,255,255,0.7)" letter-spacing="4">
    YOUR CHINA TRAVEL GUIDE
  </text>
</svg>
