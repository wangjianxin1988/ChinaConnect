---

import CommunicationGuideClient from "@/components/Guide/CommunicationGuideClient";
import EmbeddedAppRecommendation from "@/components/apps/EmbeddedAppRecommendation";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Communication Guide - ChinaConnect"
  description="Complete communication guide for China travel. SIM/eSIM options, VPN setup, essential apps, and APN configuration for staying connected."
  meta={{
    keywords: ['China SIM card', 'China eSIM', 'China VPN', 'China communication', 'China apps', 'WeChat China'],
  }}
>
  <main class="container mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm">
      <ol class="flex items-center gap-2 text-muted-foreground">
        <li><a href="/" class="hover:text-foreground transition-colors">Home</a></li>
        <li><span>/</span></li>
        <li><a href="/guide" class="hover:text-foreground transition-colors">Travel Guide</a></li>
        <li><span>/</span></li>
        <li class="text-foreground font-medium">Communication Guide</li>
      </ol>
    </nav>

    <div class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-4xl">📱</span>
        <div>
          <h1 class="text-4xl font-bold text-foreground">Communication Guide</h1>
          <p class="text-muted-foreground text-lg">通讯指南 - Complete guide for staying connected in China</p>
        </div>
      </div>
    </div>

    <!-- Stage indicator -->
    <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-8">
      <div class="flex items-center gap-2">
        <span class="text-2xl">📡</span>
        <div>
          <h2 class="font-semibold">Stage 3: Communication Preparation</h2>
          <p class="text-sm text-muted-foreground">Set up SIM/eSIM, VPN, and essential apps before arrival</p>
        </div>
      </div>
    </div>

    <CommunicationGuideClient client:load />

    <!-- Communication App Recommendations -->
    <section class="mt-12">
      <EmbeddedAppRecommendation
        client:visible
        categories={["social", "connectivity"]}
        title="Stay Connected in China"
        subtitle="Essential messaging and connectivity apps"
      />
    </section>
  </main>
</BaseLayout>