---
import VisaGuideClient from "@/components/Guide/VisaGuideClient";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="Visa Guide - ChinaConnect"
  description="Complete visa application guide for China travel. Requirements by country, application process, required documents, and tips for tourists."
  meta={{
    keywords: ['China visa guide', 'visa application', 'China tourist visa', 'L visa', 'visa requirements'],
  }}
>
  <main class="container mx-auto px-4 py-8">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm">
      <ol class="flex items-center gap-2 text-muted-foreground">
        <li><a href="/" class="hover:text-foreground transition-colors">Home</a></li>
        <li><span>/</span></li>
        <li><a href="/guide" class="hover:text-foreground transition-colors">Travel Guide</a></li>
        <li><span>/</span></li>
        <li class="text-foreground font-medium">Visa Guide</li>
      </ol>
    </nav>

    <div class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-4xl">📋</span>
        <div>
          <h1 class="text-4xl font-bold text-foreground">Visa Guide</h1>
          <p class="text-muted-foreground text-lg">签证指南 - Complete guide for China visa application</p>
        </div>
      </div>
    </div>

    <!-- Stage indicator -->
    <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-8">
      <div class="flex items-center gap-2">
        <span class="text-2xl">✈️</span>
        <div>
          <h2 class="font-semibold">Stage 1: Pre-departure Preparation</h2>
          <p class="text-sm text-muted-foreground">Apply for visa, gather documents, and prepare for your trip</p>
        </div>
      </div>
    </div>

    <VisaGuideClient client:load />
  </main>
</BaseLayout>