        "lng": 120.4953
      },
      "openingHours": "08:00-17:00",
      "ticketPrice": "40元",
      "recommendedVisitTime": "半天-1天",
      "highlights": [
        "文殊寺",
        "植物园",
        "登山步道",
        "森林氧吧"
