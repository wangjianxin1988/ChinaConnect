---

import CulturalWarningsClient from "@/components/Guide/CulturalWarningsClient";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Cultural Warnings - ChinaConnect">
  <main class="container mx-auto px-4 py-8">
    <div class="mb-8">
      <a href="/" class="text-primary hover:underline mb-4 inline-block">← Back to Home</a>
      <h1 class="text-4xl font-bold text-foreground">Cultural Warnings</h1>
      <p class="text-muted-foreground mt-2 text-lg">
        文化冲击预警 - Navigate cultural differences and avoid faux pas
      </p>
    </div>

    <CulturalWarningsClient client:load />
  </main>
</BaseLayout>
