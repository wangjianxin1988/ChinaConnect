      "recommendedVisitTime": "4-5 hours",
      "highlights": [
        "Imperial palaces",
        "Lake area",
        "Grassland",
        "Buddhist temples"
      ],
      "tips": "Arrive early. Rent electric cart inside. Wear comfortable shoes. Full day attraction."
    },
    {
