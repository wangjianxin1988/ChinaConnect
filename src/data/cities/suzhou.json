  "highlights": [
    "Humble Administrator's Garden - UNESCO",
    "Lingering Garden - Ming dynasty masterpiece",
    "Tiger Hill - Ancient pagoda and hill",
    "Shantang Street - Classic canal street",
    "Zhouzhuang - Water town Venice"
  ],
  "climate": {
    "type": "Subtropical monsoon",
    "bestMonths": [
      "April",
      "May",
      "September",
      "October",
      "November"
    ],
    "avgSummerTemp": "28C (82F)",
    "avgWinterTemp": "5C (41F)",
    "tips": "Best in spring (April-May) for garden flowers or autumn (Sept-Nov) for pleasant weather. Summer is hot and humid. Winter is cold but gardens are beautiful in snow. Plum blossoms in winter."
  },
