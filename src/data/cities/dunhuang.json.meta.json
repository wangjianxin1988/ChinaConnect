  "culturalTips": [
    {
      "category": "culture",
      "title": "Mogao Caves Respect",
      "content": "The Mogao Caves are sacred Buddhist sites. Don't photograph inside caves. Don't touch murals. Speak quietly. These are 1,000-year-old treasures.",
      "importance": "high"
    },
    {
      "category": "culture",
      "title": "Desert Environment",
      "content": "Dunhuang is at the edge of the Taklamakan Desert. The environment is fragile. Stay on marked paths, don't disturb desert wildlife, and carry out all trash.",
      "importance": "high"
    },
    {
      "category": "food",
      "title": "Dunhuang Cuisine",
      "content": "Dunhuang cuisine combines Gansu and Silk Road influences. Must-try: donkey meat yellow noodles, apricot peel drink, lamb skewers, and desert chives.",
      "importance": "high"
    },
    {
      "category": "timing",
      "title": "Book Mogao Early",
      "content": "Mogao Caves tickets sell out fast, especially in peak season (May-October). Book online weeks in advance or join morning queue very early.",
      "importance": "high"
    },
    {
      "category": "culture",
      "title": "Islamic Culture",
      "content": "Dunhuang has a significant Muslim community. Respect Islamic customs. The night market has excellent halal food options.",
      "importance": "medium"
    },
    {
      "category": "weather",
      "title": "Desert Climate",
      "content": "Desert temperatures vary greatly - hot daytime, cold nights. Even summer nights need warm layers. Bring sunscreen and water. Sandstorms can occur in spring.",
      "importance": "high"
    },
    {
      "category": "culture",
      "title": "Silk Road History",
      "content": "Dunhuang was a major Silk Road oasis where Buddhism, trade, and cultures met. The Mogao Caves were created by monks, merchants, and rulers over 1,000 years.",
      "importance": "medium"
    },
    {
      "category": "food",
      "title": "Night Market Culture",
      "content": "Shazhou Night Market is the heart of Dunhuang evening life. Try local snacks, buy souvenirs, and enjoy the atmosphere. The apricot juice is a must-try.",
      "importance": "medium"
    },
    {
      "category": "culture",
      "title": "Photography Etiquette",
      "content": "Photography is prohibited inside Mogao Caves but allowed outside. At sand dunes, remove shoes before climbing. Respect signs at archaeological sites.",
      "importance": "medium"
    },
    {
      "category": "etiquette",
      "title": "Visiting Temples",
      "content": "When visiting Buddhist sites like Leiyin Temple, walk clockwise around statues, speak softly, and make offerings if invited by monks.",
      "importance": "medium"
    },
    {
      "category": "culture",
      "title": "Starry Night",
      "content": "Dunhuang has minimal light pollution, especially at desert camps. The Milky Way is visible on clear nights. Bring a telescope or just lie back and enjoy.",
      "importance": "medium"
    },
    {
      "category": "shopping",
      "title": "Dunhuang Souvenirs",
      "content": "Look for goji berries, dried apricots, desert poplar crafts, and Buddhist art reproductions. The night market has good bargaining opportunities.",
      "importance": "low"
    },
    {
      "category": "dialect",
      "title": "Local Language",
      "content": "Mandarin is universal. Some Muslim vendors speak local dialect. Basic Mandarin phrases appreciated. Hand signals help in markets.",
      "importance": "low"
    },
    {
      "category": "etiquette",
      "title": "Desert Activities",
      "content": "When riding camels, follow handler instructions. Don't feed the animals. For sand sliding, protect electronics from sand. Wear goggles on windy days.",
      "importance": "medium"
    },
    {
      "category": "culture",
      "title": "Ancient Passes",
      "content": "Yumenguan and Yangguan passes were Silk Road fortresses. Visiting these lonely ruins with historical context creates a powerful experience of ancient travelers.",
      "importance": "medium"
    }
  ],
