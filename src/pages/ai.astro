---
import AIChatPage from '@/components/AIChatPage';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { generateBreadcrumbSchema, generateJsonLdScript } from "@/lib/seo/schema-org";

const pageTitle = "ChinaConnect AI - Your Intelligent China Travel Expert";
const pageDescription =
  "Your personal China travel intelligence — expert itinerary planning, real-time recommendations, local insights, and cultural guidance, all powered by advanced AI.";

// Schema.org JSON-LD for AI page
const aiSchemas = [
  generateBreadcrumbSchema([
    { name: "Home", url: "https://chinaconnect.com/" },
    { name: "AI Assistant", url: "https://chinaconnect.com/ai" },
  ]),
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  meta={{
    noIndex: false,
  }}
>
  <!-- Schema.org JSON-LD for SEO/GEO -->
  <script type="application/ld+json" set:html={generateJsonLdScript(aiSchemas)} />

  <AIChatPage client:only="react" />
</BaseLayout>