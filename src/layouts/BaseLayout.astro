---
import "@/styles/global.css";
import "@/styles/tailwind.css";
import { ViewTransitions } from "astro:transitions";
import EmergencyWrapper from "@/components/Emergency/EmergencyWrapper";
import CulturalWarningTrigger from "@/components/Guide/CulturalWarningTrigger";
import InstallPrompt from "@/components/pwa/InstallPrompt";
import OfflineIndicator from "@/components/pwa/OfflineIndicator";
import { type Language, SUPPORTED_LANGUAGES, translations } from "@/i18n/translations";
import { generateHreflangUrlsWithDefault } from "@/lib/hreflang";
import type { HreflangUrl, SEOPageMeta } from "@/types/seo";

interface Props {
  title: string;
  description?: string;
  meta?: Partial<SEOPageMeta>;
  ogImage?: string;
  lang?: Language;
}

const SITE_URL = "https://chinaconnect.xyz";
const SITE_NAME = "ChinaConnect";

const {
  title,
  description = "ChinaConnect - Connecting China with the World through culinary experiences",
  meta = {},
  ogImage,
  lang = "en",
} = Astro.props;

const pageMeta: SEOPageMeta = {
  title,
  description,
  ...meta,
};

// Build canonical URL using SITE_URL to avoid localhost in production
const canonicalUrl = meta.canonicalUrl || `${SITE_URL}${Astro.url.pathname}`;
const fullOgImage = ogImage || `${SITE_URL}/og-image.png`;
const pathname = Astro.url.pathname;

// Generate hreflang tags for all 12 languages
const hreflangUrls = generateHreflangUrlsWithDefault(pathname, SITE_URL);

// Map language to Open Graph locale
const ogLocaleMap: Record<Language, string> = {
  en: "en_US",
  ja: "ja_JP",
  ko: "ko_KR",
  "zh-CN": "zh_CN",
  "zh-TW": "zh_TW",
  th: "th_TH",
  vi: "vi_VN",
  ru: "ru_RU",
  fr: "fr_FR",
  de: "de_DE",
  ar: "ar_AR",
  fa: "fa_IR",
};
const currentOgLocale = ogLocaleMap[lang] || "en_US";

// Serialize translations for client-side use
const translationsJson = JSON.stringify(translations);
---

<!doctype html>
<html lang={lang} dir={lang === "ar" || lang === "fa" ? "rtl" : "ltr"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- PWA / Theme Color -->
    <meta name="theme-color" content="#3b82f6" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="ChinaConnect" />

    <!-- PWA Manifest -->
    <link rel="manifest" href="/manifest.json" />

    <!-- Primary Meta Tags -->
    <title>{pageMeta.title}</title>
    <meta name="description" content={pageMeta.description} />
    {pageMeta.keywords && pageMeta.keywords.length > 0 && (
      <meta name="keywords" content={pageMeta.keywords.join(', ')} />
    )}
    {pageMeta.noIndex ? (
      <meta name="robots" content="noindex, nofollow" />
    ) : (
      <meta name="robots" content="index, follow" />
    )}

    <!-- AI Crawler Meta (allow AI bots to crawl) -->
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="bingbot" content="index, follow" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang Tags for 12 Languages -->
    {hreflangUrls.map(({ hreflang, href }) => (
      <link rel="alternate" hreflang={hreflang} href={href} />
    ))}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageMeta.title} />
    <meta property="og:description" content={pageMeta.description} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content={currentOgLocale} />
    {SUPPORTED_LANGUAGES.filter(l => l.code !== lang).slice(0, 5).map(l => (
      <meta property="og:locale:alternate" content={ogLocaleMap[l.code]} />
    ))}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageMeta.title} />
    <meta name="twitter:description" content={pageMeta.description} />
    <meta name="twitter:image" content={fullOgImage} />
    <meta name="twitter:site" content="@chinaconnect" />

    <!-- Theme Color -->
    <meta name="theme-color" content="#3b82f6" />

    <title>{title}</title>
    <ViewTransitions />

    <!-- Inline translations for client-side i18n -->
    <script is:inline define:vars={{ translationsJson, SUPPORTED_LANGUAGES }}>
      (function() {
        var STORAGE_KEY = 'chinaconnect_language';
        var translations = JSON.parse(translationsJson);
        var languages = SUPPORTED_LANGUAGES;

        // Expose translations and languages globally for other scripts
        window.__I18N__ = {
          translations: translations,
          languages: languages
        };

        // Get current language from localStorage or browser
        function getCurrentLang() {
          var stored = localStorage.getItem(STORAGE_KEY);
          if (stored && translations[stored]) return stored;

          var browserLang = navigator.language;
          if (browserLang.startsWith('ja')) return 'ja';
          if (browserLang.startsWith('ko')) return 'ko';
          if (browserLang.startsWith('zh')) return browserLang.includes('TW') || browserLang.includes('HK') ? 'zh-TW' : 'zh-CN';
          if (browserLang.startsWith('th')) return 'th';
          if (browserLang.startsWith('vi')) return 'vi';
          if (browserLang.startsWith('ru')) return 'ru';
          if (browserLang.startsWith('ar')) return 'ar';
          if (browserLang.startsWith('fa')) return 'fa';
          if (browserLang.startsWith('de')) return 'de';
          if (browserLang.startsWith('fr')) return 'fr';
          return 'en';
        }

        var currentLang = getCurrentLang();

        // Apply translations to elements
        function applyTranslations(lang) {
          var t = translations[lang] || translations['en'];
          if (!t) return;

          document.querySelectorAll('[data-i18n]').forEach(function(el) {
            var key = el.getAttribute('data-i18n');
            var keys = key.split('.');
            var value = t;
            for (var i = 0; i < keys.length; i++) {
              value = value && value[keys[i]];
            }
            if (typeof value === 'string') {
              el.textContent = value;
            }
          });

          document.documentElement.lang = lang;
          document.documentElement.dir = (lang === 'ar' || lang === 'fa') ? 'rtl' : 'ltr';

          var langLabel = document.getElementById('lang-current');
          if (langLabel) {
            var langInfo = languages.find(function(l) { return l.code === lang; });
            if (langInfo) {
              langLabel.textContent = langInfo.code.toUpperCase().split('-')[0];
            }
          }
        }

        // Build language menu
        function buildLangMenu() {
          var list = document.getElementById('lang-list');
          if (!list) return;
          list.innerHTML = '';

          languages.forEach(function(lang) {
            var li = document.createElement('li');
            var btn = document.createElement('button');
            btn.className = 'w-full text-left px-3 py-2 text-sm hover:bg-gray-50 flex items-center justify-between gap-2';
            if (lang.code === currentLang) {
              btn.classList.add('bg-blue-50', 'text-blue-600');
            }
            btn.setAttribute('data-lang', lang.code);
            btn.innerHTML = '<span class="flex items-center gap-2"><span class="text-base">' +
              (lang.code === 'zh-CN' ? '简' : lang.code === 'zh-TW' ? '繁' : lang.code === 'en' ? 'EN' : lang.code.toUpperCase()) +
              '</span><span>' + lang.nativeName + '</span></span>' +
              (lang.code === currentLang ? '<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>' : '');
            btn.onclick = function() { switchLanguage(lang.code); };
            li.appendChild(btn);
            list.appendChild(li);
          });
        }

        window.toggleLanguageMenu = function() {
          var menu = document.getElementById('lang-menu');
          if (menu) menu.classList.toggle('hidden');
        };

        window.switchLanguage = function(lang) {
          localStorage.setItem(STORAGE_KEY, lang);
          currentLang = lang;
          applyTranslations(lang);
          buildLangMenu();
          toggleLanguageMenu();
          window.dispatchEvent(new CustomEvent('languagechange', { detail: lang }));
          // Navigate to locale-prefixed URL for SEO
          var currentPath = window.location.pathname;
          // Remove existing locale prefix
          var cleanPath = currentPath.replace(/^\/(en|ja|ko|zh-CN|zh-TW|th|vi|ru|fr|de|ar|fa)(\/|$)/, '/');
          if (lang === 'en') {
            window.location.href = cleanPath;
          } else {
            window.location.href = '/' + lang + (cleanPath === '/' ? '' : cleanPath);
          }
        };

        document.addEventListener('click', function(e) {
          var container = document.getElementById('lang-switcher-container');
          var menu = document.getElementById('lang-menu');
          if (container && !container.contains(e.target) && menu) {
            menu.classList.add('hidden');
          }
        });

        // Initialize translations
        function initI18n() {
          currentLang = getCurrentLang();
          buildLangMenu();
          applyTranslations(currentLang);
        }

        // Run on initial load
        initI18n();

        // Handle ViewTransitions - use both events to ensure we catch all navigations
        document.addEventListener('astro:after-swap', function() {
          setTimeout(initI18n, 0);
        });
        document.addEventListener('astro:page-load', function() {
          setTimeout(initI18n, 0);
        });
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-gray-200">
      <div class="container-custom">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity">
            <img src="/logo.png" alt="ChinaConnect" class="w-10 h-10 rounded-lg" />
            <div>
              <span class="font-semibold text-lg text-gray-900">ChinaConnect</span>
              <span class="block text-xs text-gray-500" data-i18n="nav.tagline">Explore China with AI</span>
            </div>
          </a>

          <!-- Desktop Nav -->
          <div class="hidden md:flex items-center gap-6">
            <a href="/" class="text-gray-600 hover:text-gray-900 font-medium transition-colors" data-i18n="nav.home">Home</a>
            <a href="/cities" class="text-gray-600 hover:text-gray-900 font-medium transition-colors" data-i18n="nav.cities">Cities</a>
            <a href="/food" class="text-gray-600 hover:text-gray-900 font-medium transition-colors" data-i18n="nav.restaurants">Restaurants</a>
            <a href="/ai" class="text-purple-600 hover:text-purple-700 font-medium transition-colors flex items-center gap-1">
              <span data-i18n="nav.aiChat">AI Expert</span>
            </a>
            <a href="/guide" class="text-gray-600 hover:text-gray-900 font-medium transition-colors" data-i18n="nav.guide">Travel Guide</a>
          </div>

          <!-- CTA -->
          <div class="flex items-center gap-3">
            <!-- Auth Button -->
            <div id="auth-nav-container"></div>
            <script is:inline>
              (async function() {
                try {
                  // Use the pre-created Supabase client from the config module (avoids creating a duplicate GoTrueClient)
                  const mod = await import('/_astro/supabase.BzczbnvH.js');
                  const supabase = mod.s || mod.default;
                  if (!supabase || !supabase.auth) {
                    // Fallback: show login link if client unavailable
                    var c = document.getElementById('auth-nav-container');
                    if (c) c.innerHTML = '<a href="/auth/login" class="flex items-center gap-2 px-4 py-1.5 rounded-lg bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium transition-colors"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>Login</a>';
                    return;
                  }
                  var timeout = new Promise(function(_, reject) { setTimeout(function() { reject(new Error('timeout')); }, 5000); });
                  var result = await Promise.race([
                    supabase.auth.getSession().then(function(r) { return r; }),
                    timeout
                  ]);
                  var session = result && result.data ? result.data.session : null;
                  var container = document.getElementById('auth-nav-container');
                  if (!container) return;
                  if (session && session.user) {
                    var user = session.user;
                    var name = user.user_metadata && (user.user_metadata.full_name || user.user_metadata.name) || (user.email ? user.email.split('@')[0] : 'User');
                    var avatar = user.user_metadata && (user.user_metadata.avatar_url || user.user_metadata.picture);
                    container.innerHTML = '<a href="/account" class="flex items-center gap-2 px-3 py-1.5 rounded-lg hover:bg-gray-100 transition-colors">'
                      + (avatar ? '<img src="' + avatar + '" class="w-7 h-7 rounded-full" alt="">' : '<div class="w-7 h-7 rounded-full bg-blue-500 text-white flex items-center justify-center text-xs font-bold">' + name.charAt(0).toUpperCase() + '</div>')
                      + '<span class="text-sm font-medium text-gray-700 hidden sm:inline">' + name + '</span></a>';
                  } else {
                    container.innerHTML = '<a href="/auth/login" class="flex items-center gap-2 px-4 py-1.5 rounded-lg bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium transition-colors">'
                      + '<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>'
                      + 'Login</a>';
                  }
                } catch(e) {
                  // On any error (timeout, import failure, etc.), show login link
                  var c2 = document.getElementById('auth-nav-container');
                  if (c2) c2.innerHTML = '<a href="/auth/login" class="flex items-center gap-2 px-4 py-1.5 rounded-lg bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium transition-colors"><svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>Login</a>';
                }
              })();
            </script>
            <!-- Language Switcher -->
            <div class="relative" id="lang-switcher-container">
              <button
                id="lang-switcher"
                class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg bg-blue-50 text-blue-600 text-sm font-medium hover:bg-blue-100 transition-colors"
                onclick="toggleLanguageMenu()"
                title="Switch Language"
              >
                <span id="lang-current">EN</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
                </svg>
              </button>
              <div id="lang-menu" class="hidden absolute right-0 mt-2 w-56 bg-white rounded-lg shadow-lg border border-gray-200 py-2 z-50 max-h-80 overflow-y-auto">
                <div class="px-3 py-2 text-xs text-gray-500 border-b border-gray-100">Select Language</div>
                <ul id="lang-list" class="py-2">
                  <!-- Populated by JS -->
                </ul>
              </div>
            </div>

          </div>
        </div>
      </div>
    </nav>

    <script is:inline>
      (function() {
        var STORAGE_KEY = 'chinaconnect_language';
        var translations = window.__I18N__.translations;
        var languages = window.__I18N__.languages;

        // Get current language
        function getCurrentLang() {
          // First check localStorage
          var stored = localStorage.getItem(STORAGE_KEY);
          if (stored) return stored;

          // Fallback to browser language detection
          var browserLang = navigator.language;
          if (browserLang.startsWith('ja')) return 'ja';
          if (browserLang.startsWith('ko')) return 'ko';
          if (browserLang.startsWith('zh')) return browserLang.includes('TW') || browserLang.includes('HK') ? 'zh-TW' : 'zh-CN';
          if (browserLang.startsWith('th')) return 'th';
          if (browserLang.startsWith('vi')) return 'vi';
          if (browserLang.startsWith('ru')) return 'ru';
          if (browserLang.startsWith('ar')) return 'ar';
          if (browserLang.startsWith('fa')) return 'fa';
          if (browserLang.startsWith('de')) return 'de';
          if (browserLang.startsWith('fr')) return 'fr';
          return 'en';
        }

        var currentLang = getCurrentLang();

        // Apply translations to elements
        function applyTranslations(lang) {
          var t = translations[lang];
          if (!t) {
            // Fallback to English if language not found
            t = translations['en'];
            if (!t) return;
            lang = 'en';
          }

          document.querySelectorAll('[data-i18n]').forEach(function(el) {
            var key = el.getAttribute('data-i18n');
            var keys = key.split('.');
            var value = t;
            for (var i = 0; i < keys.length; i++) {
              value = value && value[keys[i]];
            }
            if (typeof value === 'string') {
              el.textContent = value;
            }
          });

          // Update HTML attributes
          document.documentElement.lang = lang;
          document.documentElement.dir = (lang === 'ar' || lang === 'fa') ? 'rtl' : 'ltr';

          // Update page title if there's a translation
          if (t.nav && t.nav.home) {
            var langLabel = document.getElementById('lang-current');
            if (langLabel) {
              var langInfo = languages.find(function(l) { return l.code === lang; });
              if (langInfo) {
                langLabel.textContent = langInfo.code.toUpperCase().split('-')[0];
              }
            }
          }
        }

        // Build language menu
        function buildLangMenu() {
          var list = document.getElementById('lang-list');
          if (!list) return;
          list.innerHTML = '';

          languages.forEach(function(lang) {
            var li = document.createElement('li');
            var btn = document.createElement('button');
            btn.className = 'w-full text-left px-3 py-2 text-sm hover:bg-gray-50 flex items-center justify-between gap-2';
            if (lang.code === currentLang) {
              btn.classList.add('bg-blue-50', 'text-blue-600');
            }
            btn.setAttribute('data-lang', lang.code);
            btn.innerHTML = '<span class="flex items-center gap-2"><span class="text-base">' +
              (lang.code === 'zh-CN' ? '简' : lang.code === 'zh-TW' ? '繁' : lang.code === 'en' ? 'EN' : lang.code.toUpperCase()) +
              '</span><span>' + lang.nativeName + '</span></span>' +
              (lang.code === currentLang ? '<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>' : '');
            btn.onclick = function() { switchLanguage(lang.code); };
            li.appendChild(btn);
            list.appendChild(li);
          });
        }

        // Toggle language menu
        window.toggleLanguageMenu = function() {
          var menu = document.getElementById('lang-menu');
          menu.classList.toggle('hidden');
        };

        // Switch language
        window.switchLanguage = function(lang) {
          localStorage.setItem(STORAGE_KEY, lang);
          currentLang = lang;
          applyTranslations(lang);
          buildLangMenu();
          toggleLanguageMenu();
          // Dispatch event for other components
          window.dispatchEvent(new CustomEvent('languagechange', { detail: lang }));
          // Navigate to locale-prefixed URL for SEO
          var currentPath = window.location.pathname;
          var cleanPath = currentPath.replace(/^\/(en|ja|ko|zh-CN|zh-TW|th|vi|ru|fr|de|ar|fa)(\/|$)/, '/');
          if (lang === 'en') {
            window.location.href = cleanPath;
          } else {
            window.location.href = '/' + lang + (cleanPath === '/' ? '' : cleanPath);
          }
        };

        // Close menu on outside click
        document.addEventListener('click', function(e) {
          var container = document.getElementById('lang-switcher-container');
          var menu = document.getElementById('lang-menu');
          if (container && !container.contains(e.target)) {
            menu.classList.add('hidden');
          }
        });

        // Initialize translations
        function initI18n() {
          // Re-read translations from window in case they changed
          var trans = window.__I18N__.translations;
          var langs = window.__I18N__.languages;

          currentLang = getCurrentLang();

          // Build language menu
          var list = document.getElementById('lang-list');
          if (list) {
            list.innerHTML = '';
            langs.forEach(function(lang) {
              var li = document.createElement('li');
              var btn = document.createElement('button');
              btn.className = 'w-full text-left px-3 py-2 text-sm hover:bg-gray-50 flex items-center justify-between gap-2';
              if (lang.code === currentLang) {
                btn.classList.add('bg-blue-50', 'text-blue-600');
              }
              btn.setAttribute('data-lang', lang.code);
              btn.innerHTML = '<span class="flex items-center gap-2"><span class="text-base">' +
                (lang.code === 'zh-CN' ? '简' : lang.code === 'zh-TW' ? '繁' : lang.code === 'en' ? 'EN' : lang.code.toUpperCase()) +
                '</span><span>' + lang.nativeName + '</span></span>' +
                (lang.code === currentLang ? '<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>' : '');
              btn.onclick = function() { switchLanguage(lang.code); };
              li.appendChild(btn);
              list.appendChild(li);
            });
          }

          // Apply translations
          var t = trans[currentLang];
          if (!t) t = trans['en'];

          document.querySelectorAll('[data-i18n]').forEach(function(el) {
            var key = el.getAttribute('data-i18n');
            var keys = key.split('.');
            var value = t;
            for (var i = 0; i < keys.length; i++) {
              value = value && value[keys[i]];
            }
            if (typeof value === 'string') {
              el.textContent = value;
            }
          });

          // Update HTML attributes
          document.documentElement.lang = currentLang;
          document.documentElement.dir = (currentLang === 'ar' || currentLang === 'fa') ? 'rtl' : 'ltr';

          // Update language button label
          var langLabel = document.getElementById('lang-current');
          if (langLabel) {
            var langInfo = langs.find(function(l) { return l.code === currentLang; });
            if (langInfo) {
              langLabel.textContent = langInfo.code.toUpperCase().split('-')[0];
            }
          }
        }

        // Initialize on DOM ready
        document.addEventListener('DOMContentLoaded', function() {
          initI18n();
        });

        // Also run immediately in case DOMContentLoaded already fired
        if (document.readyState !== 'loading') {
          initI18n();
        }

        // Handle ViewTransitions (client-side navigation)
        // astro:after-swap fires right after DOM swap, before resources load
        document.addEventListener('astro:after-swap', function() {
          // Small delay to ensure DOM is ready
          setTimeout(initI18n, 10);
          setTimeout(autoTranslateContent, 100);
        });
        // Also handle astro:page-load for fallback
        document.addEventListener('astro:page-load', function() {
          setTimeout(initI18n, 50);
          setTimeout(autoTranslateContent, 150);
        });

        // Auto-translate page content (city descriptions, attraction info, etc.)
        var translationCache = {};
        try {
          var cached = localStorage.getItem('chinaconnect_translate_cache');
          if (cached) translationCache = JSON.parse(cached);
        } catch(e) {}

        function autoTranslateContent() {
          // Use server-set locale if available, otherwise use i18n currentLang
          var lang = window.__LOCALE__ || currentLang || 'en';
          if (lang === 'en') return;

          // Find all elements with data-translate attribute
          var elements = document.querySelectorAll('[data-translate]');
          if (elements.length === 0) return;

          // Translate in batches of 5
          var batch = [];
          for (var i = 0; i < elements.length; i++) {
            var el = elements[i];
            var text = el.getAttribute('data-translate') || el.textContent || '';
            if (!text.trim()) continue;

            var cacheKey = lang + ':' + text.substring(0, 80);

            // Check cache
            if (translationCache[cacheKey]) {
              if (el.children.length === 0) {
                el.textContent = translationCache[cacheKey];
              }
              continue;
            }

            batch.push({ el: el, text: text, cacheKey: cacheKey });

            if (batch.length >= 5) {
              translateBatch(batch, lang);
              batch = [];
            }
          }
          if (batch.length > 0) {
            translateBatch(batch, lang);
          }
        }

        function translateBatch(items, targetLang) {
          items.forEach(function(item) {
            fetch('/api/translate', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ text: item.text, targetLang: targetLang, sourceLang: 'zh-CN' })
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
              if (data.translated && data.translated !== item.text) {
                if (item.el.children.length === 0) {
                  item.el.textContent = data.translated;
                }
                translationCache[item.cacheKey] = data.translated;
                try {
                  localStorage.setItem('chinaconnect_translate_cache', JSON.stringify(translationCache));
                } catch(e) {}
              }
            })
            .catch(function() {});
          });
        }
      })();
    </script>

