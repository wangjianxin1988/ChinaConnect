  "culturalTips": [
    {
      "category": "food",
      "title": "Seafood Culture",
      "content": "Dalian is famous for fresh seafood. Must-try: steamed crab, salt shrimp, grilled fish, and sea urchin. The city has many seafood markets where you can pick and have food cooked.",
      "importance": "high"
    },
    {
      "category": "history",
      "title": "Russian and Japanese Heritage",
      "content": "Dalian was under Russian and Japanese control in early 20th century. The Russian Style Street and Japanese Style Street still show this colonial heritage with unique architecture.",
      "importance": "high"
    },
    {
      "category": "beach",
      "title": "Coastal City",
      "content": "Dalian has beautiful beaches including Fujiazhuang, Jinshi Beach, and Bangchui Island. Summer is peak season for beach activities and water sports.",
      "importance": "high"
    },
    {
      "category": "food",
      "title": "Menzi (焖子)",
      "content": "Pan-fried menzi is an iconic Dalian street snack made from starch. Find it at street vendors, especially near the old streets. Topped with garlic sauce and soy sauce.",
      "importance": "medium"
    },
    {
      "category": "architecture",
      "title": "European Architecture",
      "content": "Zhongshan Square and surrounding streets feature European architecture from various countries, making Dalian feel like a European city in parts.",
      "importance": "medium"
    },
    {
      "category": "nature",
      "title": "Clean City",
      "content": "Dalian is known for its clean streets and urban planning. The city has won awards for environmental improvements and green spaces.",
      "importance": "medium"
    },
    {
      "category": "food",
      "title": "Gaba Shrimp",
      "content": "Spicy raw shrimp (嘎巴虾) is a unique Dalian snack. The shrimp is marinated alive in spicy sauce and eaten whole. An acquired taste!",
      "importance": "low"
    },
    {
      "category": "history",
      "title": "Port City Heritage",
      "content": "Dalian has been a major port since Russian times. The port area still shows historical buildings and the city has strong maritime heritage.",
      "importance": "medium"
    },
    {
      "category": "dialect",
      "title": "Dalian Dialect",
      "content": "Dalian dialect is similar to standard Mandarin but with some unique expressions. Locals are known for being direct and friendly.",
      "importance": "low"
    },
    {
      "category": "transport",
      "title": "Getting Around",
      "content": "Dalian has a modern tram system and metro. The coastal scenic area is best explored by tourist bus or taxi. Bicycles are available but hilly terrain makes walking challenging.",
      "importance": "medium"
    },
    {
      "category": "shopping",
      "title": "Russian Products",
      "content": "Buy Russian chocolate, vodka, and souvenirs at the Russian Style Street. Also find local seafood products and dried seafood as souvenirs.",
      "importance": "medium"
    },
    {
      "category": "nightlife",
      "title": "Nightlife",
      "content": "Dalian has vibrant nightlife around Xinghai Square and the beach areas. Many bars and clubs cater to both locals and tourists.",
      "importance": "low"
    },
    {
      "category": "nature",
      "title": "Mountain and Sea Views",
      "content": "Dalian uniquely combines mountain and sea scenery. The coastal road offers spectacular views and there are hiking trails in the hills behind the city.",
      "importance": "medium"
    },
    {
      "category": "education",
      "title": "Education Hub",
      "content": "Dalian has several universities and is known for education. The city attracts students from across China and internationally.",
      "importance": "low"
    },
    {
      "category": "art",
      "title": "Fashion City",
      "content": "Dalian hosts international fashion events and is known for its fashion industry. The city has a modern, cosmopolitan feel.",
      "importance": "low"
    },
    {
      "category": "seasonal",
      "title": "Cherry Blossoms",
      "content": "Dalian has Japanese cherry trees that bloom in spring. The Japanese Style Street is particularly beautiful during cherry blossom season.",
      "importance": "medium"
    }
