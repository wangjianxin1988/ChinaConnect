  "culturalTips": [
    {
      "category": "food",
      "title": "Tianjin Snacks",
      "content": "Tianjin is famous for 'three treasures': Goubuli baozi, Erduoyan fried cake, and Shibajie mahua. These are must-try snacks available throughout the city.",
      "importance": "high"
    },
    {
      "category": "history",
      "title": "Colonial Heritage",
      "content": "Tianjin has nine foreign concession areas with European architecture. The Five Great Avenues area showcases Italian, French, British and other colonial buildings from the early 1900s.",
      "importance": "high"
    },
    {
      "category": "arts",
      "title": "Traditional Crafts",
      "content": "Tianjin is known for Yangliuqing New Year paintings, clay figurines, and kites. Visit the crafts shops in Ancient Culture Street for authentic souvenirs.",
      "importance": "medium"
    },
    {
      "category": "dialect",
      "title": "Tianjin Dialect",
      "content": "Tianjin dialect is known for its humor and directness. Locals are proud of their unique accent which differs significantly from Beijing dialect.",
      "importance": "low"
    },
    {
      "category": "cuisine",
      "title": "Tianjin Cuisine",
      "content": "Tianjin cuisine is known for its seafood, especially clams and river fish. The city also has famous braised dishes and rich broth soups.",
      "importance": "high"
    },
    {
      "category": "architecture",
      "title": "European Architecture",
      "content": "Walking through Five Great Avenues feels like being in Europe. The area has over 200 colonial buildings from 10 countries, now mostly housing cafes and boutiques.",
      "importance": "medium"
    },
    {
      "category": "water",
      "title": "Haihe River Culture",
      "content": "The Haihe River is central to Tianjin's identity, with historic bridges and riverside walks. Evening cruises offer beautiful views of the city skyline.",
      "importance": "medium"
    },
    {
      "category": "opera",
      "title": "Tianjin Opera",
      "content": "Tianjin is known for its traditional Peking opera performances. The Tianjin Drama票价 is worth visiting for authentic shows.",
      "importance": "medium"
    },
    {
      "category": "food",
      "title": "Mahua Culture",
      "content": "Tianjin mahua (fried dough twists) is a famous snack with crispy texture. It's often bought as a souvenir to take home.",
      "importance": "medium"
    },
    {
      "category": "history",
      "title": "Revolutionary History",
      "content": "Tianjin played a role in modern Chinese history, with various revolutionary activities. The Memorial Hall offers insights into this period.",
      "importance": "medium"
    },
    {
      "category": "location",
      "title": "Proximity to Beijing",
      "content": "Tianjin is only 30 minutes from Beijing by high-speed train, making it an easy day trip or weekend destination from the capital.",
      "importance": "high"
    },
    {
      "category": "port",
      "title": "Port City Heritage",
      "content": "As a major port, Tianjin has international influences in its food and culture. The port area offers views of modern shipping operations.",
      "importance": "medium"
    },
    {
