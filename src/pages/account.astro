---

import BaseLayout from '@/layouts/BaseLayout.astro';

// Auth is handled by middleware (SSR) and client-side JS (static).
// The account page renders a loading state and checks auth via client JS.
---

<BaseLayout title="My Account - ChinaConnect">
  <main class="min-h-screen bg-gray-50 dark:bg-gray-900 py-8 transition-colors">
    <div class="container mx-auto px-4 max-w-5xl">
      <!-- Loading state -->
      <div id="account-loading" class="flex items-center justify-center py-20">
        <div class="text-center">
          <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto mb-4"></div>
          <p class="text-gray-500 dark:text-gray-400">Loading your account...</p>
        </div>
      </div>

      <!-- Not authenticated state -->
      <div id="account-unauthenticated" class="hidden text-center py-20">
        <div class="text-6xl mb-4">🔒</div>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Sign in required</h2>
        <p class="text-gray-500 dark:text-gray-400 mb-6">Please sign in to view your account.</p>
        <a href="/auth/login" class="inline-flex items-center gap-2 bg-blue-600 text-white px-6 py-2.5 rounded-lg font-medium hover:bg-blue-700 transition-colors">
          Sign In
        </a>
      </div>

      <!-- Account content -->
      <div id="account-content" class="hidden">
        <!-- Profile Header -->
        <div class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6 transition-colors">
          <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
            <div id="user-avatar" class="w-16 h-16 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-white text-2xl font-bold shrink-0">
              ?
            </div>
            <div class="flex-1 min-w-0">
              <h1 id="user-display-name" class="text-2xl font-bold text-gray-900 dark:text-white">User</h1>
              <p id="user-email" class="text-gray-500 dark:text-gray-400 text-sm">user@example.com</p>
              <div class="flex items-center gap-3 mt-2">
                <span id="user-level" class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400">Explorer</span>
                <span id="user-points" class="text-sm text-gray-500 dark:text-gray-400">0 points</span>
              </div>
            </div>
            <div class="flex items-center gap-2 sm:gap-3 shrink-0">
              <a href="/profile" class="text-sm text-blue-600 dark:text-blue-400 hover:underline font-medium">Edit Profile</a>
              <span class="text-gray-300 dark:text-gray-600">|</span>
              <button id="signout-btn" class="text-sm text-red-500 dark:text-red-400 hover:text-red-700 dark:hover:text-red-300 hover:underline font-medium">
                Sign Out
              </button>
            </div>
          </div>
        </div>

        <!-- Tab Navigation -->
        <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 mb-6 transition-colors overflow-x-auto">
          <nav class="flex min-w-max" id="tab-nav">
            <button
              class="tab-btn flex-1 px-6 py-3.5 text-sm font-medium text-center border-b-2 transition-colors whitespace-nowrap"
              data-tab="overview"
            >
              <span class="flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" /></svg>
                Overview
              </span>
            </button>
            <button
              class="tab-btn flex-1 px-6 py-3.5 text-sm font-medium text-center border-b-2 transition-colors whitespace-nowrap"
              data-tab="usage"
            >
              <span class="flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
                Usage
              </span>
            </button>
            <button
              class="tab-btn flex-1 px-6 py-3.5 text-sm font-medium text-center border-b-2 transition-colors whitespace-nowrap"
              data-tab="billing"
            >
              <span class="flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                Billing
              </span>
            </button>
            <button
              class="tab-btn flex-1 px-6 py-3.5 text-sm font-medium text-center border-b-2 transition-colors whitespace-nowrap"
              data-tab="plans"
            >
              <span class="flex items-center justify-center gap-2">
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>
                Plans
              </span>
            </button>
          </nav>
        </div>

        <!-- Tab Panels -->

        <!-- OVERVIEW TAB -->
        <div id="tab-panel-overview" class="tab-panel">
          <!-- Quick Stats -->
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 text-center transition-colors">
              <div id="stat-tier" class="text-2xl mb-1">🆓</div>
              <div class="text-sm font-semibold text-gray-900 dark:text-white" id="stat-tier-name">Free</div>
              <div class="text-xs text-gray-500 dark:text-gray-400">Membership</div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 text-center transition-colors">
              <div class="text-2xl mb-1">💰</div>
              <div class="text-sm font-semibold text-gray-900 dark:text-white" id="stat-balance">$0.00</div>
              <div class="text-xs text-gray-500 dark:text-gray-400">Wallet Balance</div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 text-center transition-colors">
              <div class="text-2xl mb-1">🤖</div>
              <div class="text-sm font-semibold text-gray-900 dark:text-white" id="stat-ai-usage">0 / 10</div>
              <div class="text-xs text-gray-500 dark:text-gray-400">AI Requests This Month</div>
            </div>
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-4 text-center transition-colors">
              <div class="text-2xl mb-1">🗺️</div>
              <div class="text-sm font-semibold text-gray-900 dark:text-white" id="stat-routes">0</div>
              <div class="text-xs text-gray-500 dark:text-gray-400">Saved Routes</div>
            </div>
          </div>

          <!-- Membership Status -->
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 mb-6 transition-colors">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white">Membership</h2>
              <div class="flex items-center gap-3">
                <a href="/pricing" class="text-sm text-blue-600 dark:text-blue-400 hover:underline font-medium">Upgrade →</a>
              </div>
            </div>

            <!-- Membership Status Card -->
            <div id="membership-status" class="bg-gradient-to-r from-gray-50 to-blue-50 dark:from-gray-750 dark:to-blue-900/20 rounded-lg p-4 mb-4 border border-blue-100 dark:border-blue-800">
              <div class="flex items-center justify-between">
                <div>
                  <div class="text-sm text-gray-500 dark:text-gray-400">Current Plan</div>
                  <div class="text-lg font-bold text-gray-900 dark:text-white" id="membership-plan-name">Free</div>
                </div>
                <div class="text-right">
                  <div class="text-sm text-gray-500 dark:text-gray-400">Status</div>
                  <span id="membership-status-badge" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400">Active</span>
                </div>
              </div>
              <div id="membership-expiry" class="mt-3 text-sm text-gray-500 dark:text-gray-400 hidden">
                <span id="membership-expiry-text"></span>
              </div>
              <div id="manage-subscription" class="mt-3 hidden">
                <button id="manage-subscription-btn" class="text-sm text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 hover:underline font-medium">
                  Manage Subscription →
                </button>
              </div>
            </div>

            <!-- Usage Bars -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <div class="text-sm text-gray-500 dark:text-gray-400">Daily AI Requests</div>
                <div class="mt-1">
                  <div class="flex items-center gap-2">
                    <div class="flex-1 bg-gray-200 dark:bg-gray-700 rounded-full h-2">
                      <div id="ai-daily-bar" class="bg-blue-600 h-2 rounded-full transition-all" style="width: 0%"></div>
                    </div>
                    <span id="ai-daily-text" class="text-sm text-gray-600 dark:text-gray-400">0/10</span>
                  </div>
                </div>
              </div>
              <div>
                <div class="text-sm text-gray-500 dark:text-gray-400">Saved Routes</div>
                <div class="mt-1">
                  <div class="flex items-center gap-2">
                    <div class="flex-1 bg-gray-200 dark:bg-gray-700 rounded-full h-2">
                      <div id="routes-bar" class="bg-purple-600 h-2 rounded-full transition-all" style="width: 0%"></div>
                    </div>
                    <span id="routes-text" class="text-sm text-gray-600 dark:text-gray-400">0/5</span>
                  </div>
                </div>
              </div>
              <div>
                <div class="text-sm text-gray-500 dark:text-gray-400">Favorites</div>
                <div class="mt-1">
                  <div class="flex items-center gap-2">
                    <div class="flex-1 bg-gray-200 dark:bg-gray-700 rounded-full h-2">
                      <div id="favorites-bar" class="bg-pink-600 h-2 rounded-full transition-all" style="width: 0%"></div>
                    </div>
                    <span id="favorites-text" class="text-sm text-gray-600 dark:text-gray-400">0/50</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Two column layout -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Saved Routes -->
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 transition-colors">
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Saved Routes</h2>
              <div id="routes-list" class="space-y-3">
                <p class="text-sm text-gray-500 dark:text-gray-400">No saved routes yet.</p>
              </div>
            </div>

            <!-- Favorites -->
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 transition-colors">
              <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Favorites</h2>
              <div id="favorites-list" class="space-y-3">
                <p class="text-sm text-gray-500 dark:text-gray-400">No favorites yet.</p>
              </div>
            </div>
          </div>

          <!-- Recent Orders -->
          <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6 mt-6 transition-colors">
            <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Recent Orders</h2>
            <div id="orders-list">
              <p class="text-sm text-gray-500 dark:text-gray-400">No orders yet.</p>
            </div>
          </div>
        </div>

        <!-- USAGE TAB -->
        <div id="tab-panel-usage" class="tab-panel hidden">
          <div id="usage-stats-root"></div>
        </div>

        <!-- BILLING TAB -->
        <div id="tab-panel-billing" class="tab-panel hidden">
          <div id="billing-history-root"></div>
        </div>

        <!-- PLANS TAB -->
        <div id="tab-panel-plans" class="tab-panel hidden">
          <div id="plan-comparison-root"></div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>

<style>
  .tab-btn {
    border-color: transparent;
    color: #6b7280;
  }
  .tab-btn:hover {
    color: #374151;
    background: #f9fafb;
  }
  .tab-btn.active {
    border-color: #2563eb;
    color: #2563eb;
    font-weight: 600;
  }
  :global(.dark) .tab-btn {
    color: #9ca3af;
  }
  :global(.dark) .tab-btn:hover {
    color: #d1d5db;
    background: rgba(255,255,255,0.03);
  }
  :global(.dark) .tab-btn.active {
    border-color: #3b82f6;
    color: #60a5fa;
  }
</style>

<script>
  import {
    getCurrentUser,
    getUserProfile,
    getUserDashboard,
    getUserWallet,
    getUserOrders,
    getUserRoutes,
    getUserFavorites,
    signOut,
  } from '@/lib/auth/supabase-auth';
  import { clearTierCache } from '@/lib/usage-tracker';

  const loadingEl = document.getElementById('account-loading')!;
  const unauthEl = document.getElementById('account-unauthenticated')!;
  const contentEl = document.getElementById('account-content')!;

  function showSection(section: 'loading' | 'unauth' | 'content') {
    loadingEl.classList.toggle('hidden', section !== 'loading');
    unauthEl.classList.toggle('hidden', section !== 'unauth');
    contentEl.classList.toggle('hidden', section !== 'content');
  }

  function formatCurrency(amount: number): string {
    return `$${Number(amount).toFixed(2)}`;
  }

  // ─── Tab Navigation ───────────────────────────────────────────
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const tabPanels = document.querySelectorAll<HTMLElement>('.tab-panel');
  let currentTab = 'overview';
  let reactComponentsMounted = false;

  function switchTab(tabName: string) {
    currentTab = tabName;
    tabBtns.forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.tab === tabName);
    });
    tabPanels.forEach((panel) => {
      const panelTab = panel.id.replace('tab-panel-', '');
      panel.classList.toggle('hidden', panelTab !== tabName);
    });

    // Mount React components on first view
    if (!reactComponentsMounted && (tabName === 'usage' || tabName === 'billing' || tabName === 'plans')) {
      mountReactComponents();
      reactComponentsMounted = true;
    }
  }

  tabBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      if (btn.dataset.tab) switchTab(btn.dataset.tab);
    });
  });

  // Initialize first tab
  switchTab('overview');

  // ─── Mount React Components (lazy) ───────────────────────────
  async function mountReactComponents() {
    const { createElement } = await import('react');
    const { createRoot } = await import('react-dom/client');

    // UsageStats
    const usageRoot = document.getElementById('usage-stats-root');
    if (usageRoot) {
      const { UsageStats } = await import('@/components/account/UsageStats');
      createRoot(usageRoot).render(createElement(UsageStats, { language: 'en' }));
    }

    // BillingHistory
    const billingRoot = document.getElementById('billing-history-root');
    if (billingRoot) {
      const { BillingHistory } = await import('@/components/account/BillingHistory');
      createRoot(billingRoot).render(createElement(BillingHistory, { language: 'en' }));
    }

    // PlanComparison
    const plansRoot = document.getElementById('plan-comparison-root');
    if (plansRoot) {
      const { PlanComparison } = await import('@/components/account/PlanComparison');
      createRoot(plansRoot).render(createElement(PlanComparison, { language: 'en' }));
    }
  }

  // ─── Existing Overview Logic ─────────────────────────────────
  function renderRoutes(routes: any[]) {
    const container = document.getElementById('routes-list')!;
    let localRoutes: any[] = [];
    try {
      const stored = localStorage.getItem('cc_ai_saved_routes');
      if (stored) localRoutes = JSON.parse(stored);
    } catch {}
    const allRoutes = [...routes];
    for (const lr of localRoutes) {
      if (!allRoutes.find(r => r.id === lr.id)) {
        allRoutes.push(lr);
      }
    }
    if (!allRoutes || allRoutes.length === 0) {
      container.innerHTML = '<p class="text-sm text-gray-500 dark:text-gray-400">No saved routes yet. Start a conversation with AI to create routes!</p>';
      return;
    }
    container.innerHTML = allRoutes.map(r => `
      <div class="flex items-center gap-3 p-3 bg-gray-50 dark:bg-gray-750 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
        <span class="text-xl">🗺️</span>
        <div class="flex-1 min-w-0">
          <div class="text-sm font-medium text-gray-900 dark:text-white truncate">${r.title || 'Untitled Route'}</div>
          <div class="text-xs text-gray-500 dark:text-gray-400">${r.destination || r.destination_city || ''} · ${r.days || '?'} days · ${new Date(r.createdAt || r.created_at).toLocaleDateString()}</div>
          ${r.highlights && r.highlights.length > 0 ? `<div class="text-xs text-gray-400 dark:text-gray-500 mt-1 truncate">${r.highlights.slice(0, 2).join(' • ')}</div>` : ''}
        </div>
        <div class="flex items-center gap-2">
          ${r.synced === false ? '<span class="text-xs text-amber-500" title="Saved locally only">📱</span>' : '<span class="text-xs text-green-500" title="Synced to cloud">☁️</span>'}
          <button onclick="deleteRoute('${r.id}')" class="p-1 hover:bg-red-100 dark:hover:bg-red-900/30 rounded text-gray-400 hover:text-red-500" title="Delete">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
          </button>
        </div>
      </div>
    `).join('');
  }

  (window as any).deleteRoute = function(routeId: string) {
    if (!confirm('Delete this route?')) return;
    try {
      const stored = localStorage.getItem('cc_ai_saved_routes');
      if (stored) {
        const routes = JSON.parse(stored);
        const filtered = routes.filter((r: any) => r.id !== routeId);
        localStorage.setItem('cc_ai_saved_routes', JSON.stringify(filtered));
      }
    } catch {}
    loadAccount();
  };

  function renderFavorites(favorites: any[]) {
    const container = document.getElementById('favorites-list')!;
    if (!favorites || favorites.length === 0) {
      container.innerHTML = '<p class="text-sm text-gray-500 dark:text-gray-400">No favorites yet. Browse cities and restaurants to add favorites!</p>';
      return;
    }
    container.innerHTML = favorites.map(f => `
      <div class="flex items-center gap-3 p-3 bg-gray-50 dark:bg-gray-750 rounded-lg">
        <span class="text-xl">⭐</span>
        <div class="flex-1 min-w-0">
          <div class="text-sm font-medium text-gray-900 dark:text-white truncate">${f.title || f.item_type || 'Saved Item'}</div>
          <div class="text-xs text-gray-500 dark:text-gray-400">${f.item_type || ''} · ${new Date(f.created_at).toLocaleDateString()}</div>
        </div>
      </div>
    `).join('');
  }

  function renderOrders(orders: any[]) {
    const container = document.getElementById('orders-list')!;
    if (!orders || orders.length === 0) {
      container.innerHTML = '<p class="text-sm text-gray-500 dark:text-gray-400">No orders yet.</p>';
      return;
    }
    container.innerHTML = `
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-gray-200 dark:border-gray-700">
              <th class="text-left py-2 text-gray-500 dark:text-gray-400 font-medium">Order #</th>
              <th class="text-left py-2 text-gray-500 dark:text-gray-400 font-medium">Type</th>
              <th class="text-left py-2 text-gray-500 dark:text-gray-400 font-medium">Amount</th>
              <th class="text-left py-2 text-gray-500 dark:text-gray-400 font-medium">Status</th>
              <th class="text-left py-2 text-gray-500 dark:text-gray-400 font-medium">Date</th>
            </tr>
          </thead>
          <tbody>
            ${orders.map(o => `
              <tr class="border-b border-gray-100 dark:border-gray-700">
                <td class="py-2 font-mono text-xs text-gray-900 dark:text-white">${o.order_number || o.id.slice(0, 8)}</td>
                <td class="py-2 text-gray-900 dark:text-white">${(o.order_type || '-').replace('membership_', '').replace('_', ' ')}</td>
                <td class="py-2 text-gray-900 dark:text-white">${formatCurrency(o.final_amount || o.amount || 0)}</td>
                <td class="py-2">
                  <span class="px-2 py-0.5 rounded-full text-xs font-medium ${
                    o.status === 'paid' || o.status === 'completed' ? 'bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400' :
                    o.status === 'pending' || o.status === 'pending_payment' ? 'bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400' :
                    o.status === 'failed' ? 'bg-red-100 dark:bg-red-900/30 text-red-700 dark:text-red-400' :
                    'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400'
                  }">${o.status || 'unknown'}</span>
                </td>
                <td class="py-2 text-gray-500 dark:text-gray-400">${new Date(o.created_at).toLocaleDateString()}</td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    `;
  }

  async function loadAccount() {
    showSection('loading');

    const user = await getCurrentUser();
    if (!user) {
      showSection('unauth');
      return;
    }

    const [profileRes, dashboardRes, walletRes, ordersRes, routesRes, favoritesRes] = await Promise.all([
      getUserProfile(user.id),
      getUserDashboard(user.id),
      getUserWallet(user.id),
      getUserOrders(user.id, 10),
      getUserRoutes(user.id, 5),
      getUserFavorites(user.id, 5),
    ]);

    const profile = profileRes.profile;
    const dashboard = dashboardRes.dashboard;
    const wallet = walletRes.wallet;

    // Populate header
    const avatarEl = document.getElementById('user-avatar')!;
    const nameEl = document.getElementById('user-display-name')!;
    const emailEl = document.getElementById('user-email')!;
    const levelEl = document.getElementById('user-level')!;
    const pointsEl = document.getElementById('user-points')!;

    const displayName = profile?.display_name || user.email?.split('@')[0] || 'User';
    nameEl.textContent = displayName;
    emailEl.textContent = user.email || '';

    if (profile?.avatar_url) {
      avatarEl.innerHTML = `<img src="${profile.avatar_url}" alt="${displayName}" class="w-16 h-16 rounded-full object-cover" />`;
    } else {
      avatarEl.textContent = displayName.charAt(0).toUpperCase();
    }

    if (profile?.level) {
      levelEl.textContent = profile.level;
    }
    if (profile?.points !== undefined) {
      pointsEl.textContent = `${profile.points} points`;
    }

    // Populate stats
    const tierIcon = document.getElementById('stat-tier')!;
    const tierName = document.getElementById('stat-tier-name')!;
    const balance = document.getElementById('stat-balance')!;
    const aiUsage = document.getElementById('stat-ai-usage')!;
    const routesCount = document.getElementById('stat-routes')!;

    const tierIcons: Record<string, string> = {
      free: '🆓',
      pro: '⭐',
      enterprise: '💎',
      explorer: '🧭',
      traveler: '✈️',
      business: '💼'
    };

    if (dashboard) {
      const tier = (dashboard as any).tier_slug || profile?.membership_tier || 'free';
      tierIcon.textContent = tierIcons[tier] || '🆓';
      tierName.textContent = tier.charAt(0).toUpperCase() + tier.slice(1);
      localStorage.setItem('subscription_tier', tier);

      const aiUsed = (dashboard as any).ai_used_today || 0;
      const aiLimit = (dashboard as any).ai_daily_limit || 10;
      aiUsage.textContent = aiLimit === -1 ? `${aiUsed} / ∞` : `${aiUsed} / ${aiLimit}`;
      routesCount.textContent = String((dashboard as any).saved_routes || 0);

      // Usage bars
      const aiDailyBar = document.getElementById('ai-daily-bar')!;
      const aiDailyText = document.getElementById('ai-daily-text')!;
      if (aiLimit === -1) {
        aiDailyBar.style.width = '5%';
        aiDailyText.textContent = `${aiUsed} / ∞`;
      } else {
        const pct = Math.min(100, (aiUsed / aiLimit) * 100);
        aiDailyBar.style.width = `${pct}%`;
        aiDailyText.textContent = `${aiUsed}/${aiLimit}`;
      }

      const savedRoutes = (dashboard as any).saved_routes || 0;
      const maxRoutes = 5;
      const routesBar = document.getElementById('routes-bar')!;
      const routesText = document.getElementById('routes-text')!;
      routesBar.style.width = `${Math.min(100, (savedRoutes / maxRoutes) * 100)}%`;
      routesText.textContent = `${savedRoutes}/${maxRoutes}`;

      const favCount = (dashboard as any).favorites_count || 0;
      const maxFav = 50;
      const favBar = document.getElementById('favorites-bar')!;
      const favText = document.getElementById('favorites-text')!;
      favBar.style.width = `${Math.min(100, (favCount / maxFav) * 100)}%`;
      favText.textContent = `${favCount}/${maxFav}`;

      // Membership status
      const planNameEl = document.getElementById('membership-plan-name')!;
      const statusBadge = document.getElementById('membership-status-badge')!;
      const expiryEl = document.getElementById('membership-expiry')!;
      const expiryText = document.getElementById('membership-expiry-text')!;
      const manageEl = document.getElementById('manage-subscription')!;

      planNameEl.textContent = tier.charAt(0).toUpperCase() + tier.slice(1);

      const expiresAt = (dashboard as any).membership_expires_at;
      if (expiresAt) {
        expiryEl.classList.remove('hidden');
        const expiryDate = new Date(expiresAt);
        expiryText.textContent = `Renews on ${expiryDate.toLocaleDateString()}`;
        statusBadge.textContent = 'Active';
        statusBadge.className = 'inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-400';
      }

      if (tier !== 'free') {
        manageEl.classList.remove('hidden');
      }
    }

    if (wallet) {
      balance.textContent = formatCurrency((wallet as any).balance || 0);
    }

    renderRoutes(routesRes.routes || []);
    renderFavorites(favoritesRes.favorites || []);
    renderOrders(ordersRes.orders || []);

    const manageBtn = document.getElementById('manage-subscription-btn');
    if (manageBtn) {
      manageBtn.addEventListener('click', async () => {
        try {
          window.location.href = '/pricing';
        } catch (err) {
          console.error('Portal error:', err);
          alert('Could not open subscription management. Please contact support.');
        }
      });
    }

    showSection('content');
  }

  loadAccount();

  document.getElementById('signout-btn')?.addEventListener('click', async () => {
    await signOut();
    clearTierCache();
    localStorage.removeItem('subscription_tier');
    window.location.href = '/';
  });
</script>
