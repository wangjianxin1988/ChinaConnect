{
  "name": "ChinaConnect",
  "short_name": "ChinaConnect",
  "description": "AI-powered China travel guide with offline support",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#3b82f6",
  "orientation": "portrait-primary",
  "scope": "/",
  "icons": [
    {
      "src": "/icons/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icons/icon.svg",
      "sizes": "512x512",
      "type": "image/svg+xml",
      "purpose": "maskable"
    }
  ],
  "shortcuts": [
    {
      "name": "AI Assistant",
      "short_name": "AI Chat",
      "description": "Chat with AI for travel advice",
      "url": "/ai"
    },
    {
      "name": "Emergency Contacts",
      "short_name": "Emergency",
      "description": "View emergency contacts",
      "url": "/emergency"
    },
    {
      "name": "Explore Cities",
      "short_name": "Cities",
      "description": "Browse Chinese cities",
      "url": "/cities"
    }
  ],
  "categories": ["travel", "food", "lifestyle"],
  "lang": "en",
  "dir": "auto",
  "prefer_related_applications": false,
  "related_applications": [],
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "share_target": {
    "action": "/share-handler",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  }
}
