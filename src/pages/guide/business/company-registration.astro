---
import CompanyRegistrationClient from "@/components/Guide/CompanyRegistrationClient";
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout
  title="China Company Registration Guide - ChinaConnect"
  description="Step-by-step guide to registering a WFOE, Representative Office, or other entity in China as a foreign investor. Complete timeline and document checklist."
  meta={{
    keywords: ['register company China', 'WFOE registration', '外商独资企业', 'China business entity setup', '工商注册中国'],
  }}
>
  <main class="container mx-auto px-4 py-8">
    <div class="mb-8">
      <a href="/guide" class="text-primary hover:underline mb-4 inline-block flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Business Express / 商务快车道
      </a>
      <div class="flex items-center gap-3 mb-3">
        <span class="text-4xl">🏢</span>
        <div>
          <h1 class="text-3xl md:text-4xl font-bold text-foreground">Company Registration Guide</h1>
          <p class="text-muted-foreground text-lg">工商注册指南</p>
        </div>
      </div>
      <p class="text-muted-foreground max-w-2xl">
        Comprehensive guide to registering a business entity in China as a foreign investor.
        Choose between WFOE, Representative Office, and other structures.
      </p>
    </div>

    <CompanyRegistrationClient client:load />
  </main>
</BaseLayout>