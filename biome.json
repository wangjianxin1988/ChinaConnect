{
  "$schema": "https://biomejs.org/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "correctness": {
        "noUnusedVariables": "off",
        "noUnusedImports": "off"
      },
      "style": {
        "noNonNullAssertion": "off"
      },
      "a11y": {
        "noAccessKey": "off",
        "useButtonType": "off",
        "useAltText": "off",
        "noSvgWithoutTitle": "off"
      },
      "complexity": {
        "noForEach": "off",
        "useOptionalChain": "off"
      },
      "suspicious": {
        "noArrayIndexKey": "off",
        "noExplicitAny": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "jsxRuntime": "reactClassic"
  },
  "overrides": [
    {
      "include": ["**/*.astro", "node_modules/**", "dist/**"],
      "linter": {
        "rules": {
          "recommended": false,
          "correctness": {
            "noUnusedImports": "off",
            "noUnusedVariables": "off"
          }
        }
      },
      "formatter": {
        "enabled": false
      }
    },
    {
      "include": ["**/*.json"],
      "formatter": {
        "enabled": false
      }
    }
  ]
}
