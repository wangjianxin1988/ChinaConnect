  .faq-item.active .faq-content {
    max-height: 200px;
  }
  .faq-item.active .faq-arrow {
    transform: rotate(180deg);
  }
  .faq-item.active {
    border-color: #818cf8;
    box-shadow: 0 0 0 1px rgba(129, 140, 248, 0.2);
  }
</style>

<script>
  // Billing toggle
  let currentBilling: 'monthly' | 'annual' = 'monthly';

  const billingBtns = document.querySelectorAll('.billing-toggle');
  const priceAmounts = document.querySelectorAll('.price-amount');
  const annualNotes = document.querySelectorAll('.price-annual-note');
  const savingsHint = document.getElementById('savings-hint');

  billingBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const billing = btn.getAttribute('data-billing') as 'monthly' | 'annual';
      currentBilling = billing;

      // Update toggle UI
      billingBtns.forEach((b) => {
        if (b.getAttribute('data-billing') === billing) {
          b.classList.add('bg-white', 'text-gray-900', 'shadow-md');
          b.classList.remove('text-gray-500', 'hover:text-gray-700');
        } else {
          b.classList.remove('bg-white', 'text-gray-900', 'shadow-md');
          b.classList.add('text-gray-500', 'hover:text-gray-700');
        }
      });

      // Update prices with animation
      priceAmounts.forEach((el) => {
        const monthly = el.getAttribute('data-monthly');
        const annual = el.getAttribute('data-annual');
        if (monthly && annual) {
          (el as HTMLElement).style.transform = 'scale(0.95)';
          (el as HTMLElement).style.opacity = '0.5';
          setTimeout(() => {
            el.textContent = `$${billing === 'monthly' ? monthly : annual}`;
            (el as HTMLElement).style.transform = 'scale(1)';
            (el as HTMLElement).style.opacity = '1';
          }, 150);
        }
      });

      // Show/hide annual notes
      annualNotes.forEach((note) => {
        (note as HTMLElement).style.display = billing === 'annual' ? 'block' : 'none';
      });

      // Show/hide savings hint
      if (savingsHint) {
        savingsHint.style.display = billing === 'annual' ? 'block' : 'none';
      }
    });
  });

  // Initially hide annual notes and set price transition
  annualNotes.forEach((note) => {
    (note as HTMLElement).style.display = 'none';
  });
  priceAmounts.forEach((el) => {
    (el as HTMLElement).style.transition = 'transform 0.15s ease, opacity 0.15s ease';
  });

  // FAQ accordion
  document.querySelectorAll('.faq-toggle').forEach((toggle) => {
    toggle.addEventListener('click', () => {
      const item = toggle.closest('.faq-item');
      const isActive = item?.classList.contains('active');

      // Close all items
      document.querySelectorAll('.faq-item').forEach((faq) => {
        faq.classList.remove('active');
        faq.querySelector('.faq-toggle')?.setAttribute('aria-expanded', 'false');
      });

      // Open clicked item if it was closed
      if (!isActive && item) {
        item.classList.add('active');
        toggle.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Subscribe button click handler
  document.querySelectorAll('.subscribe-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const tier = btn.getAttribute('data-tier');
      if (!tier || tier === 'free') return;

      const button = btn as HTMLButtonElement;
      const originalText = button.textContent;
      button.textContent = '处理中...';
      button.disabled = true;
      button.style.opacity = '0.7';

      try {
        // Store tier for success page
        localStorage.setItem('pending_checkout_tier', tier);

        // Call checkout API
        const response = await fetch('/api/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tier, billing: currentBilling }),
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.error || 'Failed to create checkout session');
        }

        if (data.url) {
          window.location.href = data.url;
        } else {
          throw new Error('No checkout URL returned');
        }
      } catch (error: unknown) {
        const message = error instanceof Error ? error.message : 'Unknown error';
        console.error('Checkout error:', message);
        alert(`Checkout error: ${message}\n\nPlease make sure payment is configured properly.`);
        button.textContent = originalText;
        button.disabled = false;
        button.style.opacity = '1';
        localStorage.removeItem('pending_checkout_tier');
      }
    });
  });

  // Highlight current tier
  const currentTier = localStorage.getItem('subscription_tier') || 'free';
  document.querySelectorAll('[data-tier]').forEach((btn) => {
    const tier = btn.getAttribute('data-tier');
    if (tier === currentTier && btn.classList.contains('subscribe-btn')) {
      btn.textContent = '当前套餐 ✓';
      (btn as HTMLButtonElement).disabled = true;
      btn.classList.add('opacity-60', 'cursor-not-allowed');
      btn.classList.remove('subscribe-btn');
    }
    if (tier === 'free' && currentTier === 'free') {
      btn.textContent = 'Current Plan ✓';
    }
  });
</script>
