{
  "$schema": "https://biomejs.org/schemas/1.9.4/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "warn"
      },
      "style": {
        "noNonNullAssertion": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "jsxRuntime": "reactClassic"
  },
  "overrides": [
    {
      "include": [".astro/**", "node_modules/**", "dist/**"],
      "linter": {
        "rules": {
          "recommended": false
        }
      },
      "formatter": {
        "enabled": false
      }
    },
    {
      "include": ["**/*.json"],
      "formatter": {
        "enabled": false
      }
    }
  ]
}
