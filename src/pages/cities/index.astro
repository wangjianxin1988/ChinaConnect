---
import { CitiesListClient } from "@/components/city/CitiesListClient";
import { cities, citiesMeta } from "@/data/cities/index";
import { getLangFromUrl } from "@/i18n/utils";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { generateBreadcrumbSchema, generateCollectionPageSchema, generateJsonLdScript } from "@/lib/seo/schema-org";

const lang = getLangFromUrl(Astro.url);
const pageTitle = "All Cities - ChinaConnect";
const pageDescription = "Explore all Chinese cities covered by ChinaConnect - from ancient capitals to modern metropolises. S-tier premium cities, A-tier semi-premium, and D-tier on-demand cities.";

// Schema.org JSON-LD for Cities listing
const citiesSchemas = [
  generateCollectionPageSchema({
    name: "Chinese Cities on ChinaConnect",
    description: "Explore 12+ Chinese cities with ChinaConnect - from ancient capitals like Beijing and Xi'an to modern metropolises like Shanghai and Shenzhen. Find Michelin restaurants, Black Pearl establishments, and local favorites.",
    url: "https://chinaconnect.xyz/cities",
    numberOfItems: citiesMeta.length,
  }),
  generateBreadcrumbSchema([
    { name: "Home", url: "https://chinaconnect.xyz/" },
    { name: "Cities", url: "https://chinaconnect.xyz/cities" },
  ]),
];
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  meta={{
    keywords: ['China cities', 'Beijing', 'Shanghai', 'Guangzhou', "Xi'an", 'Chengdu', 'travel guide', 'S-tier cities', 'A-tier cities'],
  }}
  lang={lang}
>
  <!-- Schema.org JSON-LD for SEO/GEO -->
  <script type="application/ld+json" set:html={generateJsonLdScript(citiesSchemas)} />

  <main class="container mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2" data-i18n="cities.title">Explore All Cities</h1>
      <p class="text-gray-600" data-i18n="cities.subtitle">Discover the best of China with our comprehensive city guides</p>
    </div>

    <CitiesListClient citiesMeta={citiesMeta} citiesData={cities} client:load />
  </main>
</BaseLayout>
