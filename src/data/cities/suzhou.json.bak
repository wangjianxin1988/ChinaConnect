    {
      "id": "suzhou-bingjiang-park",
      "name": "苏州滨江公园",
      "nameEn": "Suzhou Riverside Park",
      "category": "park",
      "description": "沿太湖岸线建设的湿地公园，有观鸟台、亲水平台和骑行绿道。是观赏太湖日落和湿地生态的好地方。",
      "address": "苏州市吴中区太湖新城",
      "coordinates": {
        "lat": 31.1689,
        "lng": 120.3953
      },
      "openingHours": "全天开放",
      "ticketPrice": "免费",
      "recommendedVisitTime": "2-3小时",
      "highlights": [
        "太湖日落",
        "湿地生态",
        "观鸟台",
        "骑行绿道"
      ],
      "tips": "傍晚日落最美。骑行爱好者的好去处。",
      "image": "https://images.unsplash.com/photo-1689825650048-55d2216868f7?w=800&q=85"
    },
    {
      "id": "suzhou-chongyuan-temple",
      "name": "重元寺",
      "nameEn": "Chongyuan Temple",
      "category": "temple",
      "description": "阳澄湖畔的大型佛教寺院，有水上观音阁，供奉33米高观音像。寺院建筑宏伟，环境清幽，是苏州最大的佛教道场之一。",
      "address": "苏州市工业园区阳澄岛",
      "coordinates": {
        "lat": 31.4089,
        "lng": 120.7753
      },
      "openingHours": "08:00-17:00",
      "ticketPrice": "20元",
      "recommendedVisitTime": "1.5-2小时",
      "highlights": [
        "水上观音阁",
        "33米观音像",
        "阳澄湖风光",
        "佛教文化"
      ],
      "tips": "可以和阳澄湖大闸蟹美食结合。秋冬季节阳澄湖风光最美。",
      "image": "https://images.unsplash.com/photo-1770036491308-2fc128e47f20?w=800&q=85"
    },
    {
      "id": "suzhou-bay-wetland",
      "name": "太湖湿地公园",
      "nameEn": "Taihu Lake Wetland Park",
      "category": "nature",
      "description": "太湖边的大型湿地公园，有水上森林、芦苇荡和观鸟区。乘坐游船穿梭于湿地水道之间，可以近距离观察各种水鸟。",
      "address": "苏州市虎丘区镇湖街道",
      "coordinates": {
        "lat": 31.2389,
        "lng": 120.3753
      },
      "openingHours": "08:30-16:30",
      "ticketPrice": "60元",
      "recommendedVisitTime": "2-3小时",
      "highlights": [
        "水上森林",
        "芦苇荡",
        "观鸟",
        "游船"
      ],
      "tips": "秋冬季节候鸟最多。建议乘坐游船游览。",
      "image": "https://images.unsplash.com/photo-1624386748285-577003092e09?w=800&q=85"
    },
    {
      "id": "kezhang-garden",
      "name": "可园",
      "nameEn": "Ke Garden",
      "category": "park",
      "description": "苏州唯一的书院式园林，始建于清代，园内有学古堂、浩歌亭等建筑。与沧浪亭隔街相望，小巧精致，是文人读书讲学之所。",
      "address": "苏州市姑苏区沧浪亭街",
      "coordinates": {
        "lat": 31.2889,
        "lng": 120.6243
      },
      "openingHours": "07:30-17:30",
      "ticketPrice": "25元",
      "recommendedVisitTime": "1小时",
      "highlights": [
        "书院式园林",
        "学古堂",
        "古树名木",
        "沧浪亭对景"
      ],
      "tips": "游客很少，可以安静欣赏。建议和沧浪亭一起游览。",
      "image": "https://images.unsplash.com/photo-1759046263120-763faa804cf8?w=800&q=85"
    }
