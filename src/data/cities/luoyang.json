  "culturalTips": [
    {
      "category": "history",
      "title": "Ancient Capital",
      "content": "Luoyang served as capital for 13 dynasties over 5,000 years, making it one of China's most historically significant cities. The Longmen Grottoes and White Horse Temple are remnants of this glorious past.",
      "importance": "high"
    },
    {
      "category": "buddhism",
      "title": "Birthplace of Chinese Buddhism",
      "content": "White Horse Temple is China's first Buddhist temple, established in 68 AD when Buddhism entered China. Luoyang became the center of Chinese Buddhism.",
      "importance": "high"
    },
    {
      "category": "martial",
      "title": "Kung Fu Birthplace",
      "content": "The Shaolin Temple is recognized as the birthplace of Chinese martial arts (kung fu). Monks have practiced martial arts here for over 1,500 years.",
      "importance": "high"
    },
    {
      "category": "food",
      "title": "Luoyang Water Banquet",
      "content": "The famous 'water banquet' (水席) consists of 24 dishes served in sequence, each with broth or soup as the main component. Must-try for visitors.",
      "importance": "high"
    },
    {
      "category": "flower",
      "title": "City Flower",
      "content": "Luoyang is famous for peonies. The Peony Festival in April-May draws millions of visitors. The flowers are considered symbols of wealth and honor.",
      "importance": "medium"
    },
    {
      "category": "art",
      "title": "Longmen Grottoes",
      "content": "The Longmen Grottoes contain over 100,000 Buddhist statues carved into mountainside cliffs. The largest is 17 meters tall. A UNESCO World Heritage Site.",
      "importance": "high"
    },
    {
      "category": "dynasty",
      "title": "Tang Dynasty Legacy",
      "content": "Luoyang was a major capital during the Tang Dynasty, China's golden age. The Tang period saw great cultural flourishing in art, poetry and religion.",
      "importance": "medium"
    },
    {
      "category": "warriors",
      "title": "Terracotta Warriors Connection",
      "content": "Luoyang's connection to the Longmen Grottoes and ancient capitals makes it a complement to Xi'an's Terracotta Warriors. Both cities showcase China's imperial history.",
      "importance": "medium"
    },
    {
      "category": "martial",
      "title": "Shaolin Kung Fu School",
      "content": "Many international visitors come to Luoyang specifically to train at Shaolin Temple. Kung fu schools offer programs ranging from a few days to several months.",
      "importance": "high"
    },
    {
      "category": "food",
      "title": "Peony Flower Dish",
      "content": "Peony yan cai (牡丹燕菜) is Luoyang's signature dish, made from taro and named after the city flower. It's a must-try at traditional restaurants.",
      "importance": "medium"
    },
    {
      "category": "etiquette",
      "title": "Temple Visit Etiquette",
      "content": "When visiting Buddhist temples, remove hats, dress modestly, and avoid loud conversations. Photography may be restricted in some areas.",
      "importance": "medium"
    },
    {
      "category": "history",
      "title": "Dragon Gate Grottoes",
      "content": "The Longmen Grottoes were carved over 400 years during the Northern Wei and Tang dynasties. They represent the pinnacle of Chinese stone carving art.",
      "importance": "high"
    },
    {
      "category": "architecture",
      "title": "Ancient City Walls",
      "content": "Luoyang's old city walls and gates like Lizheng Gate and Yingtian Gate offer glimpses into the city's imperial past.",
      "importance": "low"
    },
    {
      "category": "legend",
      "title": "Legend of Baimen",
      "content": "The legend of the White Horse carrying Buddhist scriptures from India to China gave White Horse Temple its name and marked Buddhism's official entry into China.",
      "importance": "medium"
    },
    {
      "category": "crafts",
      "title": "Luoyang Tri-color Pottery",
      "content": "Tang tri-color glazed pottery (唐三彩) is famous from the Tang Dynasty. These ceramic pieces typically feature vibrant glazes in brown, yellow, and green.",
      "importance": "medium"
    }
  ],
