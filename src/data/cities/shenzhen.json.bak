  "culturalTips": [
    {
      "category": "tech",
      "title": "Tech Culture",
      "content": "Shenzhen is China's tech hub. Visit Huaqiangbei electronics market for gadgets. Experience cashless society firsthand.",
      "importance": "high"
    },
    {
      "category": "pace",
      "title": "Fast Pace",
      "content": "Shenzhen is always moving. Metro is packed during rush hours (7:30-9:00, 17:30-19:30). Plan accordingly.",
      "importance": "medium"
    },
    {
      "category": "dining",
      "title": "Dining Hours",
      "content": "Local restaurants busy during normal meal times: 11:30-13:30 and 17:30-20:30. Late-night dining common.",
      "importance": "medium"
    },
    {
      "category": "language",
      "title": "Language",
      "content": "Mandarin is primary. Cantonese widely spoken in Luohu and traditional areas. English more common in tourist areas.",
      "importance": "low"
    },
    {
      "category": "tech",
      "title": "Huaqiangbei Electronics Market",
      "content": "The world's largest electronics market at Huaqiangbei. Bargain hard, check quality carefully, and verify specifications before purchase. Bring your laptop to test components.",
      "importance": "high"
    },
    {
      "category": "startup",
      "title": "Startup Ecosystem",
      "content": "Shenzhen is home to Tencent, Huawei, BYD, and DJI. Visit Tencent's headquarters in Nanshan. The city has a unique entrepreneurial spirit born from reform and opening.",
      "importance": "medium"
    },
    {
      "category": "cashless",
      "title": "Cashless Society",
      "content": "Mobile payment is universal in Shenzhen. Alipay and WeChat Pay are used for everything from street food to taxis. Bring a phone with these apps installed.",
      "importance": "high"
    },
    {
      "category": "beach",
      "title": "Beach Culture",
      "content": "Shenzhen has beautiful beaches (Dameisha, Xiaomeisha, Jiaochangwei). Arrive early on weekends as they get crowded. Bring sunscreen - shade is limited.",
      "importance": "medium"
    },
    {
      "category": "cantonese",
      "title": "Cantonese Influence",
      "content": "While Mandarin dominates, Cantonese is still widely spoken in Luohu, Dongmen, and traditional Hakka areas. Locals appreciate when visitors try basic phrases.",
      "importance": "medium"
    },
    {
      "category": "hk-access",
      "title": "Hong Kong Access",
      "content": "Shenzhen is gateway to Hong Kong via Luohu or Futian Checkpoint. Consider a day trip to Hong Kong or use Shenzhen as base for Pearl River Delta exploration.",
      "importance": "high"
    },
    {
      "category": "theme-parks",
      "title": "Theme Park Culture",
      "content": "Shenzhen has major theme parks (Window of the World, Happy Valley, OCT Eastern). Book tickets online for discounts. Weekdays are less crowded.",
      "importance": "medium"
    },
    {
      "category": "fashion",
      "title": "Fashion and Design",
      "content": "OCT-LOFT and Dapeng Fortress host creative festivals. Shenzhen Fashion Week showcases local designers. The city blends innovation with manufacturing.",
      "importance": "low"
    },
    {
      "category": " hukou",
      "title": "Reform History",
      "content": "Shenzhen was a fishing village in 1980. Now it's 17+ million people. Visit Shenzhen Museum to understand this remarkable transformation.",
      "importance": "medium"
    },
    {
      "category": "dialect",
      "title": "Teochew Dialect",
      "content": "Shenzhen has large Teochew (潮州) population from Chaoshan. Their cuisine and culture influence local dining. Try Chaoshan beef hot pot.",
      "importance": "low"
    },
    {
      "category": "seafood",
      "title": "Seafood Dining",
      "content": "Coastal location means fresh seafood is abundant. Shekou and Dapeng have excellent seafood restaurants. Live tanks are common - pick your own.",
      "importance": "medium"
    },
    {
      "category": "nightlife",
      "title": "Nightlife Scene",
      "content": "Sea World (海上世界) in Shekou has vibrant nightlife with international bars. Coastal City and COCO Park also have good evening options.",
      "importance": "medium"
    },
    {
      "category": "art",
      "title": "Art Scene",
      "content": "Dafen Oil Painting Village creates 60% of world's oil paintings. OCT-LOFT hosts indie music and design events. Art is big business here.",
      "importance": "medium"
    },
    {
      "category": "weather",
      "title": "Typhoon Season",
      "content": "Shenzhen typhoon season is July-September. Check weather before beach trips. Major typhoons cause transit shutdowns - stay indoors.",
      "importance": "high"
    },
    {
      "category": "architecture",
      "title": "Modern Architecture",
      "content": "Shenzhen has iconic modern architecture: Ping An Finance Center (599m), Shenzhen Civic Center by Mario Botta. Architecture tours are popular.",
      "importance": "low"
    },
    {
      "category": "business",
      "title": "Business Hub",
      "content": "Shenzhen is China's Silicon Valley. Many tech companies recruit internationally. Business culture is fast-paced and efficiency-focused.",
      "importance": "medium"
    }
  ],
