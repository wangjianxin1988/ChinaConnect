                <td class="py-3 px-4 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    {/* FAQ Section */}
    <section class="py-16">
      <div class="container-custom">
        <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">Frequently Asked Questions</h2>
        <div class="max-w-3xl mx-auto space-y-6">
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-semibold text-gray-900 mb-2">When does my monthly quota reset?</h3>
            <p class="text-gray-600 text-sm">Your AI request quota resets on the 1st of each month at midnight (UTC). Unused requests do not roll over to the next month.</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-semibold text-gray-900 mb-2">Can I upgrade or downgrade at any time?</h3>
            <p class="text-gray-600 text-sm">Yes! You can change your plan at any time. When upgrading, you'll get immediate access to new features. Downgrades take effect at the start of your next billing cycle.</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-semibold text-gray-900 mb-2">What happens when I reach my AI request limit?</h3>
            <p class="text-gray-600 text-sm">You'll see a friendly reminder to upgrade your plan. You can still view your saved itineraries and use other features available in your tier.</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-semibold text-gray-900 mb-2">Is there a free trial for paid plans?</h3>
            <p class="text-gray-600 text-sm">The Free plan lets you try 3 AI requests per month. We don't offer trials for paid plans, but you can cancel anytime if you're not satisfied.</p>
          </div>
          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h3 class="font-semibold text-gray-900 mb-2">What payment methods do you accept?</h3>
            <p class="text-gray-600 text-sm">We accept all major credit cards through Stripe. Annual plans can also be paid via bank transfer. All payments are securely processed by Stripe.</p>
          </div>
        </div>
      </div>
    </section>

    {/* CTA Section */}
    <section class="py-16 bg-gradient-to-r from-blue-600 to-indigo-600">
      <div class="container-custom text-center">
        <h2 class="text-3xl font-bold text-white mb-4">Ready to Start Your China Adventure?</h2>
        <p class="text-blue-100 mb-8 max-w-xl mx-auto">Join thousands of travelers using AI to plan their perfect China trip</p>
        <a href="/ai" class="inline-block py-3 px-8 rounded-lg bg-white text-blue-600 font-semibold hover:bg-blue-50 transition-colors">
          Start Planning Now
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  // Billing toggle
  let currentBilling: 'monthly' | 'annual' = 'monthly';

  const billingBtns = document.querySelectorAll('.billing-toggle');
  const priceAmounts = document.querySelectorAll('.price-amount');
  const annualNotes = document.querySelectorAll('.price-annual-note');

  billingBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const billing = btn.getAttribute('data-billing') as 'monthly' | 'annual';
      currentBilling = billing;

      // Update toggle UI
      billingBtns.forEach((b) => {
        if (b.getAttribute('data-billing') === billing) {
          b.classList.add('bg-white', 'text-gray-900', 'shadow-sm');
          b.classList.remove('text-gray-600');
        } else {
          b.classList.remove('bg-white', 'text-gray-900', 'shadow-sm');
          b.classList.add('text-gray-600');
        }
      });

      // Update prices
      priceAmounts.forEach((el) => {
        const monthly = el.getAttribute('data-monthly');
        const annual = el.getAttribute('data-annual');
        if (monthly && annual) {
          el.textContent = `$${billing === 'monthly' ? monthly : annual}`;
        }
      });

      // Show/hide annual notes
      annualNotes.forEach((note) => {
        (note as HTMLElement).style.display = billing === 'annual' ? 'block' : 'none';
      });
    });
  });

  // Initially hide annual notes
  annualNotes.forEach((note) => {
    (note as HTMLElement).style.display = 'none';
  });

  // Subscribe button click handler
  document.querySelectorAll('.subscribe-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const tier = btn.getAttribute('data-tier');
      if (!tier || tier === 'free') return;

      const button = btn as HTMLButtonElement;
      const originalText = button.textContent;
      button.textContent = 'Redirecting...';
      button.disabled = true;

      try {
        // Store tier for success page
        localStorage.setItem('pending_checkout_tier', tier);

        // Call checkout API
        const response = await fetch('/api/checkout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ tier, billing: currentBilling }),
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.error || 'Failed to create checkout session');
        }

        if (data.url) {
          window.location.href = data.url;
        } else {
          throw new Error('No checkout URL returned');
        }
      } catch (error: unknown) {
        const message = error instanceof Error ? error.message : 'Unknown error';
        console.error('Checkout error:', message);
        alert(`Checkout error: ${message}\n\nPlease make sure Stripe is configured properly.`);
        button.textContent = originalText;
        button.disabled = false;
        localStorage.removeItem('pending_checkout_tier');
      }
    });
  });

  // Highlight current tier
  const currentTier = localStorage.getItem('subscription_tier') || 'free';
  document.querySelectorAll('[data-tier]').forEach((btn) => {
    const tier = btn.getAttribute('data-tier');
    if (tier === currentTier && btn.classList.contains('subscribe-btn')) {
      btn.textContent = 'Current Plan';
      (btn as HTMLButtonElement).disabled = true;
      btn.classList.add('opacity-60', 'cursor-not-allowed');
    }
    if (tier === 'free' && currentTier === 'free') {
      btn.textContent = 'Current Plan';
    }
  });
</script>
