  "culturalTips": [
    {
      "id": "naxi-culture",
      "title": "纳西族文化",
      "content": "丽江是纳西族聚居地，他们有独特的东巴文化，包括世界上唯一仍在使用的象形文字。东巴文化强调人与自然和谐相处。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "mosuo-traditions",
      "title": "摩梭人走婚文化",
      "content": "泸沽湖地区居住着摩梭人，他们保留着母系社会的'走婚'传统。游客应尊重这一文化，不应以猎奇心态看待。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "old-town-etiquette",
      "title": "古城游览礼仪",
      "content": "丽江古城是UNESCO遗产，游览时请保持安静，不要在室内吸烟。古城木质结构多，防火意识要强。部分区域需要购票进入。",
      "category": "practical",
      "importance": "medium"
    },
    {
      "id": "jade-mountain-sacred",
      "title": "玉龙雪山圣山",
      "content": "玉龙雪山是纳西族神山，被视为天堂的阶梯。请尊重当地宗教信仰，不要在山上大声喧哗或做出不敬行为。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "tiger-leaping-gorge-hiking",
      "title": "虎跳峡徒步礼仪",
      "content": "虎跳峡是世界上最深的峡谷之一，徒步时请走指定步道，不要离开步道进入未开发区域。注意落石标志，安全第一。",
      "category": "practical",
      "importance": "medium"
    },
    {
      "id": "dongba-script",
      "title": "东巴文字",
      "content": "东巴文是目前世界上唯一广泛使用的象形文字，可以学习写自己的名字作为纪念。在古城很多地方可以找到东巴文化体验。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "naxi-music",
      "title": "纳西古乐",
      "content": "纳西古乐已有上千年历史，演奏者是当地老人。演出每晚在古城举行，是了解纳西文化的好机会。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "yunnan's-uv",
      "title": "高原紫外线",
      "content": "丽江海拔2400米，紫外线强烈。即使阴天也要涂防晒霜，戴太阳镜和帽子。高原干燥，多喝水。",
      "category": "health",
      "importance": "medium"
    },
    {
      "id": "altitude-consideration-lijiang",
      "title": "高原反应预防",
      "content": "丽江海拔较高（2400米），初到可能会有轻微高原反应。多休息，少运动，多喝水。前往雪山时反应可能更明显。",
      "category": "health",
      "importance": "medium"
    },
    {
      "id": "tea-horse-road",
      "title": "茶马古道",
      "content": "丽江曾是茶马古道的重要枢纽，马帮从这里前往西藏和东南亚。古城里可以看到当年马帮文化的遗迹。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "naxi-cuisine",
      "title": "纳西饮食文化",
      "content": "纳西菜口味偏辣，常用腌制食品。腊排骨是丽江名菜，米灌肠也很特色。不要错过当地的野生菌火锅（雨季）。",
      "category": "food",
      "importance": "medium"
    },
    {
      "id": "photography-respects",
      "title": "摄影礼仪",
      "content": "拍摄当地人或民族服饰前请先征得同意。纳西老人有时不喜欢被拍照，尤其是东巴祭司。山上的经幡和白塔也要先问再拍。",
      "category": "practical",
      "importance": "medium"
    },
    {
      "id": "old-town-water-system",
      "title": "古城水系",
      "content": "丽江古城水系从玉龙雪山引水，穿城而过。游客不应在河沟里洗东西或丢弃杂物。冬天水会结冰，是别样风景。",
      "category": "practical",
      "importance": "medium"
    },
    {
      "id": "naxi-barriers",
      "title": "纳西族禁忌",
      "content": "纳西族有一些传统禁忌：不要用脚踏锅灶，不要在产妇房前逗留，不要在家中唱纳西情歌。这些禁忌正在逐渐淡化，但尊重仍是必要的。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "haggling-culture",
      "title": "购物还价",
      "content": "在古城购物还价是文化的一部分。通常可以还到标价的40-60%。从友善的交谈开始，保持微笑，以建立良好关系。",
      "category": "shopping",
      "importance": "medium"
    },
    {
      "id": "tibetan-culture-lijiang",
      "title": "藏族文化影响",
      "content": "丽江靠近藏区，受藏族文化影响显著。玉龙雪山周边有藏传佛教寺庙和转经筒，请保持安静和尊重。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "lijiang-nights",
      "title": "丽江夜生活",
      "content": "古城夜晚有酒吧街，但晚上10点后请降低音量，不要影响古城居民休息。纳西老人需要早睡早起的生活。",
      "category": "practical",
      "importance": "medium"
    },
    {
      "id": "naxi-dongba-religion",
      "title": "东巴教信仰",
      "content": "纳西族信奉东巴教，这是以自然崇拜为核心的宗教。请尊重东巴祭司，他们在古城进行宗教活动时请不要打扰。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "old-town-water-system-history",
      "title": "古城水系历史",
      "content": "丽江古城水系从玉龙雪山引水，由明代木氏土司设计。水系有灌溉、防火、生活三重功能，体现了纳西人的智慧。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "lijiang-harness-culture",
      "title": "纳西织锦文化",
      "content": "纳西族有精湛的织锦传统，纳西女性的披星戴月服饰是著名标志。购买织锦产品时可以还价，但请尊重手工艺价值。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "mosuo-matrilineal-society",
      "title": "摩梭母系社会",
      "content": "泸沽湖摩梭人保留母系社会制度，家庭以女性为中心。走婚制度下，男方夜间来访天亮离开，孩子由女方家庭抚养。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "lijiang-rose-products",
      "title": "丽江玫瑰产业",
      "content": "丽江玫瑰产业发达，玫瑰饼、玫瑰糖、玫瑰酒都是特色产品。食用玫瑰种植在玉龙雪山脚下，品质优良。",
      "category": "food",
      "importance": "medium"
    },
    {
      "id": "jade-dragon-mountain-sacred",
      "title": "玉龙雪山宗教意义",
      "content": "玉龙雪山在纳西语中意为'天山'，是纳西族保护神三多的化身。山上有藏传佛教寺庙，转经筒和经幡是常见元素。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "tiger-leaping-gorge-hiking-safety",
      "title": "虎跳峡徒步安全",
      "content": "虎跳峡徒步有一定风险，7-8月雨季可能有泥石流。徒步时请走正规步道，不要离开步道进入未开发区域。建议雇当地向导。",
      "category": "practical",
      "importance": "medium"
    },
    {
      "id": "lijiang-handicraft-souvenirs",
      "title": "纳西手工艺品",
      "content": "纳西扎染、东巴木雕、银饰是主要手工艺品。购买时请认准手工艺人作品，避免买到机器批量生产的产品。",
      "category": "shopping",
      "importance": "medium"
    },
    {
      "id": "lijiang-pork-ribs-tradition",
      "title": "腊排骨腌制传统",
      "content": "腊排骨是丽江名菜，猪排骨用盐和香料腌制后风干。传统做法需要腌制一个月以上，才能形成独特的风味。",
      "category": "food",
      "importance": "medium"
    },
    {
      "id": "naxi-ancient-music-preservation",
      "title": "纳西古乐保护",
      "content": "纳西古乐是联合国非物质文化遗产，由纳西老人传承演奏。这些乐曲源自唐代，有些已失传于中原，在丽江保存下来。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "lijiang-altitude-health",
      "title": "丽江高原健康",
      "content": "丽江海拔2400米，部分游客可能有高原反应。多喝水，避免剧烈运动，如有严重头疼或呼吸困难请立即就医。",
      "category": "health",
      "importance": "medium"
    },
    {
      "id": "tea-horse-road-history",
      "title": "茶马古道商贸",
      "content": "丽江曾是茶马古道重要枢纽，马帮从这里前往西藏和东南亚。古城的四方街就是当年马帮交易的市场。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "lijiang-silk-history",
      "title": "纳西丝绸传统",
      "content": "纳西族有养蚕织绸的传统，纳西服饰中的'披星戴月'七星披肩就是用自织布料制成。现在这种传统技艺正在复兴。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "mosuo-boat-culture",
      "title": "摩梭猪槽船",
      "content": "泸沽湖的猪槽船是摩梭人传统水上交通工具，用整根木头凿成。乘船游湖是体验泸沽湖的最佳方式。",
      "category": "practical",
      "importance": "medium"
    },
    {
      "id": "naxi-mountain-photo-ethics",
      "title": "雪山摄影礼仪",
      "content": "拍摄玉龙雪山最好在清晨，这时云雾少，能看到山峰全貌。山顶经常有云雾遮挡，请耐心等待。",
      "category": "practical",
      "importance": "medium"
    },
    {
      "id": "lijiang-rose-cake-history",
      "title": "鲜花饼的由来",
      "content": "鲜花饼是丽江特色小吃，用新鲜玫瑰花瓣和面粉制成。清乾隆年间开始流行，是茶马古道马帮的便携干粮。",
      "category": "food",
      "importance": "medium"
    },
    {
      "id": "naxi-family-structure",
      "title": "纳西族家庭结构",
      "content": "传统纳西族家庭以女性为主，家务和农活主要由女性承担。男性负责手工艺和赶马帮，这种分工延续至今。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "lijiang-impression-show-history",
      "title": "印象丽江创作",
      "content": "《印象丽江》由著名导演张艺谋执导，在玉龙雪山脚下实景演出。500名演员都是当地纳西族和少数民族。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "lijiang-medicinal-herbs",
      "title": "丽江药材文化",
      "content": "丽江是云南重要药材产地，天麻、三七、虫草等都有出产。购买药材请到正规店铺，注意辨别真伪。",
      "category": "food",
      "importance": "medium"
    },
    {
      "id": "naxi-barbecue-tradition",
      "title": "纳西烤肉传统",
      "content": "纳西烤肉用炭火烤制猪肉条，是下酒好菜。传统做法要在野外用松木炭火慢烤，现在古城餐馆都有供应。",
      "category": "food",
      "importance": "medium"
    },
    {
      "id": "old-town-architecture-protection",
      "title": "古城建筑保护",
      "content": "丽江古城建筑是木质结构，部分建筑已有数百年历史。请不要在古建筑内使用明火，不要吸烟，共同保护这一世界遗产。",
      "category": "practical",
      "importance": "medium"
    },
    {
      "id": "lijiang-tsampa-culture",
      "title": "青稞糌粑文化",
      "content": "糌粑是藏族和纳西族的主食，用青稞炒熟后磨成面粉。吃法是将糌粑粉加入酥油茶中搅拌，是高原地区的高热量食物。",
      "category": "food",
      "importance": "medium"
    },
    {
      "id": "mosuo-female-power",
      "title": "摩梭女性地位",
      "content": "摩梭社会以女性为核心，家庭财产由女性继承。家中最年长的女性掌管家庭事务，男性是舅舅角色协助抚养外甥。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "lijiang-yak-meat-tradition",
      "title": "牦牛肉饮食",
      "content": "丽江周边高原牧区养牦牛，牦牛肉是当地特色。高原牦牛生长缓慢，肉质紧实，富含蛋白质，是健康食材。",
      "category": "food",
      "importance": "medium"
    },
    {
      "id": "naxi-writing-system",
      "title": "纳西东巴文",
      "content": "东巴文是世界上唯一仍在使用的象形文字，目前有1400多个字符。在古城可以学习写东巴文，制作专属纪念品。",
      "category": "culture",
      "importance": "medium"
    },
    {
      "id": "lijiang-weather-tips",
      "title": "丽江天气建议",
      "content": "丽江天气变化快，一天内可能有四季。雨季(6-8月)常有大雨，雪季(12-2月)玉龙雪山有积雪。出行前查看天气预报。",
      "category": "practical",
      "importance": "medium"
    }
  ],
