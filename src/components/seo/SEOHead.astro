---

// SEO Head component for Astro pages
// Handles meta tags, Open Graph, Twitter Card, and Schema.org JSON-LD

import { generateHreflangUrlsWithDefault } from "@/lib/hreflang";
import type { SEOPageMeta } from "@/types/seo";

interface Props {
  meta: SEOPageMeta;
  ogImage?: string;
  defaultOgImage?: string;
  siteUrl?: string;
  siteName?: string;
}

const {
  meta,
  ogImage,
  defaultOgImage = "/og-image.png",
  siteUrl = "https://chinaconnect.xyz",
} = Astro.props;

const fullOgImage = ogImage || `${siteUrl}${defaultOgImage}`;
const canonicalUrl = meta.canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const hreflangs = generateHreflangUrlsWithDefault(Astro.url.pathname, siteUrl);
---

<!-- Primary Meta Tags -->
<title>{meta.title}</title>
<meta name="description" content={meta.description} />
{-meta.keywords && meta.keywords.length > 0 && (
  <meta name="keywords" content={meta.keywords.join(', ')} />
)}
{canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
<meta name="generator" content={Astro.generator} />
{meta.noIndex && <meta name="robots" content="noindex, nofollow" />}
{meta.noFollow && !meta.noIndex && <meta name="robots" content="index, nofollow" />}
{!meta.noIndex && !meta.noFollow && <meta name="robots" content="index, follow" />}

<!-- Hreflang Tags -->
{hreflangs.map(({ hreflang, href }) => (
  <link rel="alternate" hreflang={hreflang} href={href} />
))}
<link rel="alternate" hreflang="x-default" href={canonicalUrl} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={meta.title} />
<meta property="og:description" content={meta.description} />
<meta property="og:image" content={fullOgImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="ChinaConnect" />
<meta property="og:locale" content="en_US" />
<meta property="og:locale:alternate" content="zh_CN" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={meta.title} />
<meta name="twitter:description" content={meta.description} />
<meta name="twitter:image" content={fullOgImage} />
<meta name="twitter:url" content={canonicalUrl} />
<meta name="twitter:site" content="@chinaconnect" />

<!-- Theme Color -->
<meta name="theme-color" content="#3b82f6" />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />