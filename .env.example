# ============================================
# ChinaConnect Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================
# Supabase Configuration (Required)
# ============================================
# Replace with your actual Supabase project credentials
PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: For server-side operations
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# SUPABASE_PROJECT_ID=your-project-id

# ============================================
# MiniMax AI Configuration (Primary AI)
# ============================================
# Get your API key from: https://platform.minimaxi.com/
# PUBLIC_MINIMAX_API_KEY=your-minimax-api-key-here

# ============================================
# Dify AI Configuration (Optional - for advanced workflows)
# ============================================
# Dify is an optional AI platform for complex workflow automation
# If not configured, the system falls back to MiniMax + ReAct engine
#
# Get your API key from: https://dify.ai/
# VITE_DIFY_API_URL=https://api.dify.ai/v1
# VITE_DIFY_API_KEY=your-dify-api-key-here
# VITE_DIFY_WORKFLOW_ID=your-workflow-id-here

# ============================================
# Amap (高德地图) API Configuration
# ============================================
# Get your API key at https://console.amap.com/dev/key/app
# VITE_AMAP_WEB_API_KEY=your-amap-web-api-key
# AnySearch provides real-time web search capabilities via MCP
# If not configured, the system uses local city database
# ANYSEARCH_API_KEY=your-anysearch-api-key
# ANYSEARCH_MCP_URL=https://api.anysearch.ai/mcp

# ============================================
# Application Settings
# ============================================
# VITE_APP_NAME=ChinaConnect
# VITE_APP_VERSION=1.0.0

# ============================================
# Flarum Forum Configuration (Optional)
# ============================================
# Flarum provides the community forum with SSO integration
# If not configured, the community page will show a setup prompt
#
# Get your Flarum URL from your deployed forum instance
# Get SSO secret from Flarum Admin > Settings > Authentication
# Get API key from Flarum Admin > Settings > API
PUBLIC_FLARUM_URL=https://forum.chinaconnect.example.com

# SSO Secret Key (generate with: openssl rand -hex 32)
FLARUM_SSO_SECRET=your-32-char-minimum-secret-key-here

# Flarum API Key (from admin panel)
FLARUM_API_KEY=your-flarum-api-key-here
