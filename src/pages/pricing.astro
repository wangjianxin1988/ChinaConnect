    {/* Feature Comparison Table */}
    <section class="py-20 bg-gray-50">
      <div class="container-custom">
        <div class="text-center mb-14">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Compare All Features</h2>
          <p class="text-gray-600 max-w-xl mx-auto">See exactly what's included in each plan. All plans include access to our AI-powered travel assistant.</p>
        </div>
        <div class="overflow-x-auto max-w-5xl mx-auto">
          <table class="w-full bg-white rounded-2xl shadow-lg overflow-hidden">
            <thead>
              <tr class="border-b-2 border-gray-100">
                <th class="text-left py-5 px-8 font-bold text-gray-900 text-base">Feature</th>
                <th class="text-center py-5 px-5 font-bold text-gray-500 text-sm">Free</th>
                <th class="text-center py-5 px-5 font-bold text-blue-600 text-sm bg-blue-50/50">Explorer</th>
                <th class="text-center py-5 px-5 font-bold text-purple-600 text-sm">Traveler</th>
                <th class="text-center py-5 px-5 font-bold text-amber-600 text-sm">Business</th>
              </tr>
            </thead>
            <tbody>
              <tr class="border-b border-gray-50 hover:bg-gray-50/50 transition-colors">
                <td class="py-4 px-8 text-sm font-medium text-gray-700">AI Requests per Month</td>
                <td class="py-4 px-5 text-center text-sm text-gray-600">5</td>
                <td class="py-4 px-5 text-center text-sm font-semibold text-blue-600 bg-blue-50/30">20</td>
                <td class="py-4 px-5 text-center text-sm font-semibold text-purple-600">40</td>
                <td class="py-4 px-5 text-center text-sm font-bold text-green-600">Unlimited ∞</td>
              </tr>
              <tr class="border-b border-gray-50 bg-gray-50/30 hover:bg-gray-50/50 transition-colors">
                <td class="py-4 px-8 text-sm font-medium text-gray-700">Save Itineraries</td>
                <td class="py-4 px-5 text-center"><span class="text-gray-300 text-lg">—</span></td>
                <td class="py-4 px-5 text-center bg-blue-50/30"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg></td>
                <td class="py-4 px-5 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg></td>
                <td class="py-4 px-5 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg></td>
              </tr>
              <tr class="border-b border-gray-50 hover:bg-gray-50/50 transition-colors">
                <td class="py-4 px-8 text-sm font-medium text-gray-700">Conversation History</td>
                <td class="py-4 px-5 text-center"><span class="text-gray-300 text-lg">—</span></td>
                <td class="py-4 px-5 text-center bg-blue-50/30"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg></td>
                <td class="py-4 px-5 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg></td>
                <td class="py-4 px-5 text-center"><svg class="w-5 h-5 text-green-500 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg></td>
              </tr>
              <tr class="border-b border-gray-50 bg-gray-50/30 hover:bg-gray-50/50 transition-colors">
                <td class="py-4 px-8 text-sm font-medium text-gray-700">PDF Export</td>
