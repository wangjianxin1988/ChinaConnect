---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Page Not Found - ChinaConnect" description="The page you're looking for doesn't exist.">
  <main class="min-h-[70vh] flex items-center justify-center bg-gray-50">
    <div class="text-center px-4">
      <div class="text-8xl mb-6">🗺️</div>
      <h1 class="text-5xl font-bold text-gray-900 mb-4">404</h1>
      <p class="text-xl text-gray-600 mb-2">Page Not Found</p>
      <p class="text-gray-500 mb-8 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved. 
        Let's get you back on track.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="px-6 py-3 bg-blue-600 text-white rounded-xl font-semibold hover:bg-blue-700 transition-colors">
          Go Home
        </a>
        <a href="/cities" class="px-6 py-3 bg-white border border-gray-300 text-gray-700 rounded-xl font-semibold hover:bg-gray-50 transition-colors">
          Explore Cities
        </a>
        <a href="/ai" class="px-6 py-3 bg-purple-600 text-white rounded-xl font-semibold hover:bg-purple-700 transition-colors">
          Ask AI Concierge
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
