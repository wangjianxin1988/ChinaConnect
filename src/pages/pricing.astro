---

/**
 * Pricing Page - Professional Redesign
 * Displays subscription tiers, feature comparison, FAQ, and testimonials
 * Integrates with Creem Checkout for real payments
 */
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Pricing Plans - ChinaConnect AI";
const description = "Choose the perfect AI travel assistant plan for your China journey. From free to unlimited, find the plan that fits your needs.";
const cancelled = Astro.url.searchParams.get('cancelled');
---

<BaseLayout title={title} description={description}>
  <main class="min-h-screen">
    {/* Cancelled notice */}
    {cancelled && (
      <div class="bg-amber-50 border-b border-amber-200 py-3 px-4 text-center">
        <p class="text-sm text-amber-800 font-medium">
          ⚠️ Payment was cancelled. You can try again below.
        </p>
      </div>
    )}

    {/* Hero Section */}
    <section class="relative overflow-hidden bg-gradient-to-br from-indigo-600 via-purple-600 to-blue-700 py-20 md:py-28">
      {/* Background decorative elements */}
      <div class="absolute inset-0 opacity-10">
        <div class="absolute top-0 left-1/4 w-96 h-96 bg-white rounded-full blur-3xl -translate-y-1/2"></div>
        <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-white rounded-full blur-3xl translate-y-1/2"></div>
      </div>
      <div class="container-custom relative z-10 text-center">
        <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm rounded-full px-4 py-1.5 mb-6">
          <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
          <span class="text-sm text-white/90 font-medium">Trusted by 10,000+ travelers</span>
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">
          Simple, Transparent Pricing
        </h1>
        <p class="text-lg md:text-xl text-blue-100 max-w-2xl mx-auto leading-relaxed">
          Unlock the full potential of AI-powered travel planning for China.<br class="hidden md:block" />
          Start free, upgrade when you need more.
        </p>
      </div>
    </section>

    {/* Billing Toggle */}
    <section class="pt-12 pb-4">
      <div class="container-custom text-center">
        <div class="inline-flex items-center bg-gray-100 rounded-xl p-1.5 shadow-sm">
          <button
            id="billing-monthly"
            class="billing-toggle px-6 py-2.5 rounded-lg text-sm font-semibold bg-white text-gray-900 shadow-md transition-all duration-200"
            data-billing="monthly"
          >
            Monthly
          </button>
          <button
            id="billing-annual"
            class="billing-toggle px-6 py-2.5 rounded-lg text-sm font-semibold text-gray-500 hover:text-gray-700 transition-all duration-200 relative"
            data-billing="annual"
          >
            Annual
            <span class="ml-1.5 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold bg-green-100 text-green-700">-20%</span>
          </button>
        </div>
        <p id="savings-hint" class="text-sm text-gray-500 mt-3 hidden">
          💰 Save up to <span class="font-semibold text-green-600">$72/year</span> with annual billing
        </p>
      </div>
    </section>

    {/* Pricing Cards */}
    <section class="pb-20 pt-4">
      <div class="container-custom">
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-5 max-w-6xl mx-auto items-start">
          
          {/* Free */}
          <div class="pricing-card group bg-white rounded-2xl border border-gray-200 p-7 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="text-center mb-6">
              <div class="w-14 h-14 rounded-2xl bg-gray-100 flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
                <span class="text-3xl">🆓</span>
              </div>
              <h3 class="text-xl font-bold text-gray-900">Free</h3>
              <p class="text-sm text-gray-500 mt-1">Get started with basic planning</p>
            </div>
            <div class="text-center mb-6 pb-6 border-b border-gray-100">
              <div class="flex items-baseline justify-center gap-1">
                <span class="text-5xl font-extrabold text-gray-900 price-amount" data-monthly="0" data-annual="0">$0</span>
                <span class="text-gray-400 text-sm price-period">/mo</span>
              </div>
              <p class="text-xs text-gray-400 mt-2 price-annual-note hidden">Free forever</p>
            </div>
            <ul class="space-y-3 mb-8 text-left">
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700">5 AI requests per month</span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700">Basic travel planning</span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700">View itineraries</span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-gray-300 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                <span class="text-gray-400 line-through">Save itineraries</span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-gray-300 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                <span class="text-gray-400 line-through">PDF export</span>
              </li>
            </ul>
            <button class="w-full py-3 px-4 rounded-xl border-2 border-gray-200 text-gray-500 font-semibold cursor-default text-sm" data-tier="free" disabled>
              Current Plan
            </button>
          </div>

          {/* Explorer - POPULAR */}
          <div class="pricing-card group bg-white rounded-2xl border-2 border-blue-500 p-7 shadow-lg shadow-blue-500/10 hover:shadow-2xl hover:-translate-y-1 transition-all duration-300 relative lg:-mt-4">
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
              <span class="bg-gradient-to-r from-blue-600 to-indigo-600 text-white text-xs font-bold px-4 py-1.5 rounded-full shadow-md uppercase tracking-wider">Most Popular</span>
            </div>
            <div class="text-center mb-6">
              <div class="w-14 h-14 rounded-2xl bg-blue-50 flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
                <span class="text-3xl">🧭</span>
              </div>
              <h3 class="text-xl font-bold text-gray-900">Explorer</h3>
              <p class="text-sm text-gray-500 mt-1">Best for casual travelers</p>
            </div>
            <div class="text-center mb-6 pb-6 border-b border-gray-100">
              <div class="flex items-baseline justify-center gap-1">
                <span class="text-5xl font-extrabold text-blue-600 price-amount" data-monthly="4.99" data-annual="3.99">$4.99</span>
                <span class="text-gray-400 text-sm price-period">/mo</span>
              </div>
              <p class="text-xs text-green-600 mt-2 font-medium price-annual-note hidden">Billed $47.99/year (save $12)</p>
              <p class="text-xs text-gray-400 mt-1">连续包月 · 按月自动扣款</p>
              <p class="text-xs text-gray-400">自动续费，随时取消</p>
            </div>
            <ul class="space-y-3 mb-8 text-left">
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700 font-medium">20 AI requests per month</span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700">Save itineraries</span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700">Conversation history</span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700">Priority support</span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-gray-300 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
                <span class="text-gray-400 line-through">PDF export</span>
              </li>
            </ul>
            <button class="w-full py-3 px-4 rounded-xl bg-gradient-to-r from-blue-600 to-indigo-600 text-white font-semibold hover:from-blue-700 hover:to-indigo-700 transition-all duration-200 shadow-md shadow-blue-500/25 subscribe-btn text-sm" data-tier="explorer">
              立即订阅 →
            </button>
          </div>

          {/* Traveler */}
          <div class="pricing-card group bg-white rounded-2xl border border-purple-200 p-7 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="text-center mb-6">
              <div class="w-14 h-14 rounded-2xl bg-purple-50 flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
                <span class="text-3xl">✈️</span>
              </div>
              <h3 class="text-xl font-bold text-gray-900">Traveler</h3>
              <p class="text-sm text-gray-500 mt-1">For frequent China visitors</p>
            </div>
            <div class="text-center mb-6 pb-6 border-b border-gray-100">
              <div class="flex items-baseline justify-center gap-1">
                <span class="text-5xl font-extrabold text-purple-600 price-amount" data-monthly="9.99" data-annual="7.99">$9.99</span>
                <span class="text-gray-400 text-sm price-period">/mo</span>
              </div>
              <p class="text-xs text-green-600 mt-2 font-medium price-annual-note hidden">Billed $95.99/year (save $24)</p>
              <p class="text-xs text-gray-400 mt-1">连续包月 · 按月自动扣款</p>
              <p class="text-xs text-gray-400">自动续费，随时取消</p>
            </div>
            <ul class="space-y-3 mb-8 text-left">
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700 font-medium">40 AI requests per month</span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700">Save & export itineraries</span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700">PDF export</span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700">Premium customization</span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700">Advanced travel tools</span>
              </li>
            </ul>
            <button class="w-full py-3 px-4 rounded-xl bg-gradient-to-r from-purple-600 to-violet-600 text-white font-semibold hover:from-purple-700 hover:to-violet-700 transition-all duration-200 shadow-md shadow-purple-500/25 subscribe-btn text-sm" data-tier="traveler">
              立即订阅 →
            </button>
          </div>

          {/* Business */}
          <div class="pricing-card group bg-white rounded-2xl border border-amber-200 p-7 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="text-center mb-6">
              <div class="w-14 h-14 rounded-2xl bg-amber-50 flex items-center justify-center mx-auto mb-4 group-hover:scale-110 transition-transform">
                <span class="text-3xl">💼</span>
              </div>
              <h3 class="text-xl font-bold text-gray-900">Business</h3>
              <p class="text-sm text-gray-500 mt-1">For travel professionals</p>
            </div>
            <div class="text-center mb-6 pb-6 border-b border-gray-100">
              <div class="flex items-baseline justify-center gap-1">
                <span class="text-5xl font-extrabold text-amber-600 price-amount" data-monthly="29.99" data-annual="23.99">$29.99</span>
                <span class="text-gray-400 text-sm price-period">/mo</span>
              </div>
              <p class="text-xs text-green-600 mt-2 font-medium price-annual-note hidden">Billed $287.99/year (save $72)</p>
              <p class="text-xs text-gray-400 mt-1">连续包月 · 按月自动扣款</p>
              <p class="text-xs text-gray-400">自动续费，随时取消</p>
            </div>
            <ul class="space-y-3 mb-8 text-left">
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700 font-bold">Unlimited AI requests</span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700">All Traveler features</span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700">Business templates</span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700">Team collaboration</span>
              </li>
              <li class="flex items-start gap-3 text-sm">
                <svg class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
                <span class="text-gray-700">API access & dedicated support</span>
              </li>
            </ul>
            <button class="w-full py-3 px-4 rounded-xl bg-gradient-to-r from-amber-500 to-orange-500 text-white font-semibold hover:from-amber-600 hover:to-orange-600 transition-all duration-200 shadow-md shadow-amber-500/25 subscribe-btn text-sm" data-tier="business">
              立即订阅 →
            </button>
          </div>
        </div>

        {/* Trust badges */}
        <div class="flex flex-wrap items-center justify-center gap-6 mt-12 text-sm text-gray-500">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
            <span>Secure payments</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" /></svg>
            <span>Cancel anytime</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-purple-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
            <span>Instant access</span>
          </div>
        </div>
      </div>
