---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { citiesMeta, cities } from "@/data/cities/index";
import { getLangFromUrl } from "@/i18n/utils";
import { CitiesListClient } from "@/components/city/CitiesListClient";

const lang = getLangFromUrl(Astro.url);
const pageTitle = "All Cities - ChinaConnect";
const pageDescription = "Explore all Chinese cities covered by ChinaConnect - from ancient capitals to modern metropolises. S-tier premium cities, A-tier semi-premium, and D-tier on-demand cities.";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  meta={{
    keywords: ['China cities', 'Beijing', 'Shanghai', 'Guangzhou', "Xi'an", 'Chengdu', 'travel guide', 'S-tier cities', 'A-tier cities'],
  }}
  lang={lang}
>
  <main class="container mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2" data-i18n="cities.title">Explore All Cities</h1>
      <p class="text-gray-600" data-i18n="cities.subtitle">Discover the best of China with our comprehensive city guides</p>
    </div>

    <CitiesListClient citiesMeta={citiesMeta} citiesData={cities} client:load />
  </main>
</BaseLayout>
