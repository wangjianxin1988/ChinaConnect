  "culturalTips": [
    {
      "category": "winter",
      "title": "Ice Festival",
      "content": "Harbin Ice and Snow Festival (December-February) is the world's largest, featuring massive illuminated ice sculptures at Ice and Snow World. Dress extremely warmly.",
      "importance": "high"
    },
    {
      "category": "history",
      "title": "Russian Heritage",
      "content": "Harbin was founded by Russians in 1898 as a railway hub. The city retains significant Russian architecture, especially around Central Avenue and Saint Sophia Cathedral.",
      "importance": "high"
    },
    {
      "category": "architecture",
      "title": "European Architecture",
      "content": "The city has buildings from 10+ countries including Russian, French, German, Italian and Japanese. Central Avenue showcases this eclectic mix.",
      "importance": "medium"
    },
    {
      "category": "food",
      "title": "Russian Influence",
      "content": "Try Russian food at historic restaurants like Huamei. Sample Harbin sausage, Russian bread, and the famous Modern Hotel ice cream.",
      "importance": "high"
    },
    {
      "category": "food",
      "title": "Northeast Cuisine",
      "content": "Harbin cuisine is hearty Northeast Chinese food. Must-try: fried dumplings, pork knuckle, blood sausage, and iron pot stews.",
      "importance": "medium"
    },
    {
      "category": "winter",
      "title": "Extreme Cold",
      "content": "Winters are extremely cold (-20C to -30C). Wear multiple layers, cover extremities, and limit outdoor time. Ice Festival stays open late but dress warmly.",
      "importance": "high"
    },
    {
      "category": "culture",
      "title": "Orthodox Christianity",
      "content": "Saint Sophia Cathedral is the largest surviving Orthodox church in the Far East. It now houses a museum showcasing Harbin's Christian heritage.",
      "importance": "medium"
    },
    {
      "category": "nature",
      "title": "Siberian Tigers",
      "content": "Visit the Siberian Tiger Park for a chance to see these magnificent animals. Feed them from the safety of a tour bus.",
      "importance": "medium"
    },
    {
      "category": "food",
      "title": "Spring Pancakes",
      "content": "Harbin is famous for spring pancakes (春饼) - thin crepes wrapped around various fillings. Lao Chang Spring Pancakes is the most famous chain.",
      "importance": "medium"
    },
    {
      "category": "transport",
      "title": "Winter Transport",
      "content": "Public transport runs normally in winter but some roads may be slippery. Taxis are available but can be hard to catch during snow.",
      "importance": "medium"
    },
    {
      "category": "shopping",
      "title": "Russian Goods",
      "content": "Buy Russian chocolate, vodka, and souvenirs at Central Avenue shops. Qiulin Company and Russian goods stores have authentic products.",
      "importance": "medium"
    },
    {
      "category": "history",
      "title": "Japanese Occupation",
      "content": "Harbin has museums and memorials documenting its history during Japanese occupation. The city played a significant role in modern Chinese history.",
      "importance": "medium"
    },
    {
      "category": "culture",
      "title": "Music Heritage",
      "content": "Harbin has a strong classical music tradition. The Harbin Summer Music Concert was famous during the Soviet era.",
      "importance": "low"
    },
    {
      "category": "food",
      "title": "Harbin Beer",
      "content": "Harbin Beer is China's oldest beer brand, founded by Russians in 1900. Try it fresh at local beer halls.",
      "importance": "medium"
    },
    {
      "category": "winter",
      "title": "Frozen Food",
      "content": "In winter, Harbin sells frozen fruits like hawthorn and pears on sticks - a unique winter treat. Also try frozen dumplings.",
      "importance": "low"
    },
    {
      "category": "nature",
      "title": "Songhua River",
      "content": "The frozen Songhua River is a winter playground. Walk on the ice, try ice slides, and see locals enjoying winter activities.",
      "importance": "medium"
    }
  ],
